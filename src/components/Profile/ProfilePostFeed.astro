---
import CommentSheet from "@/features/feed/CommentSheet.astro";

interface Props {
  authorAuthId:   string;
  viewerId:       string | null;
  viewerAvatar:   string | null;
  viewerUsername: string | null;
}

const { authorAuthId, viewerId, viewerAvatar, viewerUsername } = Astro.props;
---

<section class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

  <!-- Header -->
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
    <h2 class="section-title">Posts</h2>
    <span id="profile-post-count" class="text-xs text-gray-400 font-medium"></span>
  </div>

  <!-- Post list (populated by JS) -->
  <div id="profile-post-list" class="divide-y divide-gray-100">
    <!-- Skeleton -->
    <div id="profile-post-skeleton" class="p-4 space-y-3">
      {[1,2,3].map(() => (
        <div class="animate-pulse space-y-2">
          <div class="flex items-center gap-2">
            <div class="w-16 h-4 bg-gray-100 rounded-full"></div>
            <div class="w-10 h-4 bg-gray-100 rounded-full"></div>
          </div>
          <div class="w-full h-4 bg-gray-100 rounded"></div>
          <div class="w-3/4 h-4 bg-gray-100 rounded"></div>
          <div class="w-1/2 h-3 bg-gray-100 rounded mt-1"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Load more -->
  <div id="profile-load-more-wrap" class="hidden px-5 py-4 border-t border-gray-100 text-center">
    <button
      id="profile-load-more"
      type="button"
      class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition disabled:opacity-40"
    >
      Load more posts
    </button>
  </div>

</section>

<!-- CommentSheet — needed if FeedCard buttons are used elsewhere on the page -->
<CommentSheet userAvatar={viewerAvatar} username={viewerUsername} />

<style>
  .section-title {
    font-size: 10px; font-weight: 700; color: #9CA3AF;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
</style>

<script define:vars={{ authorAuthId, viewerId: viewerId ?? null }} is:inline>
  window.__PROFILE_AUTHOR_ID__ = authorAuthId;
  window.__PROFILE_VIEWER_ID__ = viewerId;
</script>

<script>
  import { actions } from "astro:actions";
  import { PUBLIC_R2_URL } from "astro:env/client";

  const AUTHOR_ID   = (window as any).__PROFILE_AUTHOR_ID__;
  const LIMIT       = 10;

  const list        = document.getElementById("profile-post-list");
  const skeleton    = document.getElementById("profile-post-skeleton");
  const countEl     = document.getElementById("profile-post-count");
  const loadMoreWrap = document.getElementById("profile-load-more-wrap");
  const loadMoreBtn  = document.getElementById("profile-load-more") as HTMLButtonElement | null;

  let totalCount = 0;

  // ── Helpers ────────────────────────────────────────────────────────────────
  function esc(s: any) {
    return String(s ?? "")
      .replace(/&/g, "&amp;").replace(/</g, "&lt;")
      .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function timeAgo(dateStr: string) {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1)  return "just now";
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24)  return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    if (days < 7)  return `${days}d ago`;
    return new Date(dateStr).toLocaleDateString("en-PH", { month: "short", day: "numeric" });
  }

  function mediaHtml(urls: string[]) {
    if (!urls?.length) return "";
    const resolve = (u: string) => u.startsWith("http") ? u : `${PUBLIC_R2_URL}${u}`;
    if (urls.length === 1) {
      return `<div class="mt-3 rounded-xl overflow-hidden aspect-video bg-gray-100">
        <img src="${esc(resolve(urls[0]))}" alt="" class="w-full h-full object-cover" loading="lazy" />
      </div>`;
    }
    const cols = urls.length === 2 ? "grid-cols-2" : urls.length === 3 ? "grid-cols-3" : "grid-cols-2";
    const shown = urls.slice(0, Math.min(4, urls.length));
    const extra = urls.length > 4 ? urls.length - 4 : 0;
    const cells = shown.map((u, i) => {
      const isLast = i === shown.length - 1 && extra > 0;
      return `<div class="relative aspect-square bg-gray-100 overflow-hidden rounded-lg">
        <img src="${esc(resolve(u))}" alt="" class="w-full h-full object-cover" loading="lazy" />
        ${isLast ? `<div class="absolute inset-0 bg-black/50 flex items-center justify-center text-white font-bold text-lg">+${extra}</div>` : ""}
      </div>`;
    }).join("");
    return `<div class="mt-3 grid ${cols} gap-1">${cells}</div>`;
  }

  function postCardHtml(post: any) {
    const photos: string[] = post.media_urls ?? [];

    const hashtags = (post.hashtags ?? []).length
      ? `<div class="flex flex-wrap gap-1.5 mt-2">${(post.hashtags as string[]).map((h: string) =>
          `<span class="text-xs text-blue-500">#${esc(h)}</span>`).join("")}</div>`
      : "";

    const counts = [
      post.like_count    > 0 ? `${post.like_count} likes`    : "",
      post.comment_count > 0 ? `${post.comment_count} comments` : "",
      post.share_count   > 0 ? `${post.share_count} reached`  : "",
    ].filter(Boolean).join(" · ");

    return `
      <a href="/post/${esc(post.post_id)}"
         class="block p-4 hover:bg-gray-50 transition-colors"
         data-post-id="${esc(post.post_id)}">
        <div class="flex items-center gap-1.5 mb-2">
          <span class="text-xs text-gray-400">${timeAgo(post.created_at)}</span>
          ${post.trip_title
            ? `<span class="text-gray-200">·</span>
               <span class="text-xs text-blue-600 font-medium truncate max-w-[160px]">${esc(post.trip_title)}</span>`
            : ""}
        </div>
        ${post.title
          ? `<p class="text-sm font-semibold text-gray-900 leading-snug mb-1">${esc(post.title)}</p>`
          : ""}
        <div class="text-sm text-gray-600 leading-relaxed line-clamp-3">${post.content}</div>
        ${hashtags}
        ${mediaHtml(photos)}
        ${counts ? `<p class="text-xs text-gray-400 mt-3">${counts}</p>` : ""}
      </a>`;
  }

  function emptyState() {
    return `<div class="py-14 px-6 text-center">
      <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h6m-6-4h2"/>
        </svg>
      </div>
      <p class="text-sm font-semibold text-gray-600 mb-1">No posts yet</p>
      <p class="text-xs text-gray-400">This traveler hasn't shared any posts.</p>
    </div>`;
  }

  // ── Load posts ─────────────────────────────────────────────────────────────
  async function loadPosts(page: number) {
    const res = await actions.feed.getUserPosts({ authorId: AUTHOR_ID, page, limit: LIMIT });

    if (page === 1) skeleton?.remove();

    if (res.error || !res.data?.posts?.length) {
      if (page === 1) list!.innerHTML = emptyState();
      loadMoreWrap?.classList.add("hidden");
      return;
    }

    const { posts } = res.data;
    if (page === 1) {
      totalCount = res.data.totalCount as number;
      if (countEl) countEl.textContent = `${totalCount} post${totalCount !== 1 ? "s" : ""}`;
    }

    list!.insertAdjacentHTML("beforeend", posts.map((p: any) => postCardHtml(p)).join(""));

    const loaded = page * LIMIT;
    if (loaded < totalCount) {
      loadMoreWrap?.classList.remove("hidden");
      if (loadMoreBtn) {
        loadMoreBtn.disabled    = false;
        loadMoreBtn.textContent = "Load more posts";
        loadMoreBtn.dataset.page = String(page + 1);
      }
    } else {
      loadMoreWrap?.classList.add("hidden");
    }
  }

  loadMoreBtn?.addEventListener("click", async () => {
    const page = parseInt(loadMoreBtn.dataset.page ?? "2", 10);
    loadMoreBtn.disabled    = true;
    loadMoreBtn.textContent = "Loading…";
    await loadPosts(page);
  });

  // Initial load
  loadPosts(1);
</script>
