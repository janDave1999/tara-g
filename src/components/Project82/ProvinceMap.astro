---
import { PH_PROVINCES } from "@/data/phProvinces";

interface Visit {
  id: string;
  province_key: string;
  stage: string;
  visit_date: string | null;
  trip_id: string | null;
  notes: string | null;
  is_auto_detected: boolean;
}

interface Props {
  visits: Visit[];
}

const { visits } = Astro.props;
---

<div id="province-map-container" class="relative w-full h-full bg-sky-50 flex items-start justify-center overflow-hidden">
  <!-- Loading overlay -->
  <div id="map-loading" class="absolute inset-0 flex flex-col items-center justify-center z-10 bg-sky-50">
    <div class="w-8 h-8 border-[3px] border-emerald-400 border-t-transparent rounded-full animate-spin mb-3"></div>
    <p class="text-sm text-gray-500 font-medium">Loading map…</p>
    <p id="map-loading-progress" class="text-xs text-gray-400 mt-1">0 / 82</p>
  </div>

  <!-- SVG map (populated by client script) -->
  <svg
    id="province-map-svg"
    class="w-full h-full"
    viewBox="0 0 600 1000"
    preserveAspectRatio="xMidYMin meet"
    style="display:none"
  ></svg>

  <!-- Legend -->
  <div id="map-legend" class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm rounded-xl px-3 py-2.5 shadow-md text-xs space-y-1.5 hidden">
    <p class="font-semibold text-gray-500 uppercase tracking-wide text-[10px] mb-1">Visit Stage</p>
    {[
      { label: 'Not visited',          color: '#E5E7EB' },
      { label: 'Pass through',         color: '#3B82F6' },
      { label: 'Short stay',           color: '#FBBF24' },
      { label: 'Extended stay',        color: '#F97316' },
      { label: 'Thorough exploration', color: '#EF4444' },
    ].map(item => (
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-sm shrink-0 border border-white shadow-sm" style={`background:${item.color}`}></span>
        <span class="text-gray-600">{item.label}</span>
      </div>
    ))}
  </div>
</div>

<script define:vars={{ visits, PH_PROVINCES }}>
  const STAGE_COLORS = {
    pass_through:         '#3B82F6',
    short_stay:           '#FBBF24',
    extended_stay:        '#F97316',
    thorough_exploration: '#EF4444',
  };
  const DEFAULT_FILL   = '#E5E7EB';
  const DEFAULT_STROKE = '#ffffff';

  // Philippines geographic bounds
  const BOUNDS = { minLng: 116.87, maxLng: 126.60, minLat: 4.58, maxLat: 21.12 };
  const SVG_W = 600, SVG_H = 1000;

  // Province key → geojson slug overrides (when slugify(name) doesn't match filename)
  const SLUG_OVERRIDES = { NCO: 'north-cotabato' };

  function getSlug(province) {
    if (SLUG_OVERRIDES[province.key]) return SLUG_OVERRIDES[province.key];
    return province.name
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\w-]+/g, '')
      .replace(/--+/g, '-');
  }

  function project(lng, lat) {
    const x = ((lng - BOUNDS.minLng) / (BOUNDS.maxLng - BOUNDS.minLng)) * SVG_W;
    const y = (1 - (lat - BOUNDS.minLat) / (BOUNDS.maxLat - BOUNDS.minLat)) * SVG_H;
    return [x, y];
  }

  function geometryToPath(geometry) {
    const polygons = geometry.type === 'MultiPolygon'
      ? geometry.coordinates
      : [geometry.coordinates];

    return polygons
      .flatMap(polygon =>
        polygon.map(ring => {
          const pts = ring.map(([lng, lat]) => project(lng, lat));
          return 'M' + pts.map(([x, y]) => `${x.toFixed(1)},${y.toFixed(1)}`).join('L') + 'Z';
        })
      )
      .join(' ');
  }

  // Build visit lookup map: province_key → visit object
  const visitMap = new Map(visits.map(v => [v.province_key, v]));

  async function init() {
    const svg        = document.getElementById('province-map-svg');
    const loadingEl  = document.getElementById('map-loading');
    const progressEl = document.getElementById('map-loading-progress');
    const legendEl   = document.getElementById('map-legend');
    if (!svg) return;

    let loaded = 0;
    const total = PH_PROVINCES.length;

    const results = await Promise.allSettled(
      PH_PROVINCES.map(async province => {
        const slug = getSlug(province);
        const res = await fetch(`/geojson/${slug}.geojson`);
        if (!res.ok) throw new Error(`Not found: ${slug}`);
        const data = await res.json();
        loaded++;
        if (progressEl) progressEl.textContent = `${loaded} / ${total}`;
        return { province, geometry: data.geometry };
      })
    );

    const ns = 'http://www.w3.org/2000/svg';
    const g  = document.createElementNS(ns, 'g');

    results.forEach(result => {
      if (result.status === 'rejected') return;
      const { province, geometry } = result.value;

      const visit = visitMap.get(province.key);
      const fill  = visit ? (STAGE_COLORS[visit.stage] ?? DEFAULT_FILL) : DEFAULT_FILL;

      const path = document.createElementNS(ns, 'path');
      path.setAttribute('d', geometryToPath(geometry));
      path.setAttribute('fill', fill);
      path.setAttribute('stroke', DEFAULT_STROKE);
      path.setAttribute('stroke-width', '0.5');
      path.setAttribute('stroke-linejoin', 'round');
      path.setAttribute('data-key', province.key);
      path.style.cursor = 'pointer';
      path.style.transition = 'fill 0.25s ease, opacity 0.15s ease';

      // Tooltip via <title>
      const title = document.createElementNS(ns, 'title');
      title.textContent = visit
        ? `${province.name} — ${visit.stage.replace(/_/g, ' ')}`
        : `${province.name} — not visited`;
      path.appendChild(title);

      path.addEventListener('mouseenter', () => path.setAttribute('opacity', '0.75'));
      path.addEventListener('mouseleave', () => path.removeAttribute('opacity'));

      path.addEventListener('click', () => {
        const v = visitMap.get(province.key);
        (window).openVisitModal({
          id:              v?.id,
          province_key:    province.key,
          province_name:   province.name,
          province_region: `Region ${province.region}`,
          stage:           v?.stage,
          visit_date:      v?.visit_date ?? null,
          notes:           v?.notes ?? null,
        });
      });

      g.appendChild(path);
    });

    svg.appendChild(g);

    // Hide loader, show map + legend
    if (loadingEl) loadingEl.remove();
    svg.style.display = '';
    legendEl?.classList.remove('hidden');
  }

  // Live update on save
  window.addEventListener('province-visit-saved', e => {
    const { province_key, stage, visit } = e.detail;
    visitMap.set(province_key, visit);
    const path = document.querySelector(`[data-key="${province_key}"]`);
    if (path) {
      path.setAttribute('fill', STAGE_COLORS[stage] ?? DEFAULT_FILL);
      const title = path.querySelector('title');
      if (title) title.textContent = `${visit.province_key} — ${stage.replace(/_/g, ' ')}`;
    }
  });

  // Live update on delete
  window.addEventListener('province-visit-deleted', e => {
    const { province_key } = e.detail;
    visitMap.delete(province_key);
    const path = document.querySelector(`[data-key="${province_key}"]`);
    if (path) {
      path.setAttribute('fill', DEFAULT_FILL);
      const title = path.querySelector('title');
      if (title) {
        const province = PH_PROVINCES.find(p => p.key === province_key);
        if (province) title.textContent = `${province.name} — not visited`;
      }
    }
  });

  // Bulk repaint after sync — replaces entire visitMap and repaints all paths
  window.addEventListener('province-sync-complete', e => {
    const { visits: newVisits } = e.detail;
    visitMap.clear();
    for (const v of newVisits) visitMap.set(v.province_key, v);

    document.querySelectorAll('[data-key]').forEach(path => {
      const key = path.getAttribute('data-key');
      if (!key) return;
      const visit = visitMap.get(key);
      path.setAttribute('fill', visit ? (STAGE_COLORS[visit.stage] ?? DEFAULT_FILL) : DEFAULT_FILL);
      const title = path.querySelector('title');
      if (title) {
        const province = PH_PROVINCES.find(p => p.key === key);
        title.textContent = visit
          ? `${province?.name ?? key} — ${visit.stage.replace(/_/g, ' ')}`
          : `${province?.name ?? key} — not visited`;
      }
    });
  });

  init();
</script>
