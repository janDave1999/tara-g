---
// No props — opened programmatically via window.openVisitModal(data)
---

<dialog
  id="visit-modal"
  class="rounded-2xl shadow-2xl p-0 w-full max-w-sm mx-auto backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div id="visit-form">
    <!-- Header -->
    <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 px-5 py-4 flex items-start justify-between rounded-t-2xl">
      <div>
        <h2 id="modal-province-name" class="text-lg font-bold text-white">Province</h2>
        <p id="modal-province-region" class="text-emerald-100 text-xs mt-0.5">Region</p>
      </div>
      <button
        type="button"
        id="modal-close"
        class="text-white/70 hover:text-white transition-colors ml-4 mt-0.5"
        aria-label="Close"
      >
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="px-5 py-4 space-y-4 bg-white">
      <!-- Stage selector -->
      <div>
        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-2">
          Visit Stage
        </label>
        <div class="grid grid-cols-1 gap-2" id="stage-options">
          {[
            { value: 'pass_through',         label: 'Pass Through',         desc: 'Transit, less than a day', color: '#3B82F6' },
            { value: 'short_stay',           label: 'Short Stay',           desc: '~1 day',                  color: '#FBBF24' },
            { value: 'extended_stay',        label: 'Extended Stay',        desc: '2–3 days',                color: '#F97316' },
            { value: 'thorough_exploration', label: 'Thorough Exploration', desc: '4+ days',                 color: '#EF4444' },
          ].map(s => (
            <label
              class="stage-label flex items-center gap-3 p-2.5 rounded-xl border border-gray-200 cursor-pointer hover:bg-gray-50 transition-colors"
              data-value={s.value}
            >
              <input type="radio" name="stage" value={s.value} class="sr-only" />
              <span class="w-3 h-3 rounded-full shrink-0" style={`background:${s.color}`}></span>
              <span class="flex-1">
                <span class="text-sm font-medium text-gray-800">{s.label}</span>
                <span class="text-xs text-gray-400 block">{s.desc}</span>
              </span>
              <span class="check-icon hidden text-emerald-500">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
            </label>
          ))}
        </div>
        <p id="stage-error" class="text-xs text-red-500 mt-1 hidden">Please select a visit stage.</p>
      </div>

      <!-- Visit date -->
      <div>
        <label for="modal-visit-date" class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">
          Visit Date <span class="font-normal normal-case">(optional)</span>
        </label>
        <input
          type="date"
          id="modal-visit-date"
          class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-400"
        />
      </div>

      <!-- Notes -->
      <div>
        <label for="modal-notes" class="text-xs font-semibold text-gray-500 uppercase tracking-wide block mb-1">
          Notes <span class="font-normal normal-case">(optional)</span>
        </label>
        <textarea
          id="modal-notes"
          rows="2"
          placeholder="What did you do there?"
          class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-emerald-400"
        ></textarea>
      </div>
    </div>

    <!-- Footer -->
    <div class="px-5 pb-5 pt-2 bg-white rounded-b-2xl flex gap-2">
      <button
        type="button"
        id="modal-delete"
        class="hidden px-4 py-2.5 rounded-xl border border-red-200 text-red-500 text-sm font-semibold hover:bg-red-50 transition-colors"
      >
        Delete
      </button>
      <button
        type="button"
        id="modal-save"
        class="flex-1 px-4 py-2.5 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-semibold transition-colors disabled:opacity-50"
      >
        Save Visit
      </button>
    </div>
  </div>
</dialog>

<script>
  type VisitData = {
    id?: string;
    province_key: string;
    province_name: string;
    province_region: string;
    stage?: string;
    visit_date?: string | null;
    notes?: string | null;
  };

  const dialog = document.getElementById('visit-modal') as HTMLDialogElement;
  const saveBtn = document.getElementById('modal-save') as HTMLButtonElement;
  const deleteBtn = document.getElementById('modal-delete') as HTMLButtonElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;
  const stageError = document.getElementById('stage-error') as HTMLElement;

  let currentProvince: VisitData | null = null;
  let isExisting = false;
  let selectedStage: string | null = null;

  function setStage(value: string | null) {
    selectedStage = value;
    document.querySelectorAll<HTMLElement>('.stage-label').forEach(label => {
      const isSelected = label.dataset.value === value;
      label.classList.toggle('border-emerald-400', isSelected);
      label.classList.toggle('bg-emerald-50', isSelected);
      label.classList.toggle('border-gray-200', !isSelected);
      const check = label.querySelector('.check-icon');
      check?.classList.toggle('hidden', !isSelected);
      const radio = label.querySelector('input[type="radio"]') as HTMLInputElement | null;
      if (radio) radio.checked = isSelected;
    });
  }

  // Stage label click
  document.querySelectorAll<HTMLElement>('.stage-label').forEach(label => {
    label.addEventListener('click', () => {
      setStage(label.dataset.value ?? null);
      stageError.classList.add('hidden');
    });
  });

  // Open modal
  (window as any).openVisitModal = (data: VisitData) => {
    currentProvince = data;
    isExisting = !!data.id;

    (document.getElementById('modal-province-name') as HTMLElement).textContent = data.province_name;
    (document.getElementById('modal-province-region') as HTMLElement).textContent = data.province_region;

    // Reset
    setStage(data.stage ?? null);
    (document.getElementById('modal-visit-date') as HTMLInputElement).value = data.visit_date ?? '';
    (document.getElementById('modal-notes') as HTMLTextAreaElement).value = data.notes ?? '';
    stageError.classList.add('hidden');
    saveBtn.textContent = 'Save Visit';
    saveBtn.disabled = false;
    deleteBtn.disabled = false;
    deleteBtn.classList.toggle('hidden', !isExisting);

    dialog.showModal();
  };

  closeBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

  saveBtn.addEventListener('click', async () => {
    if (!currentProvince) return;

    if (!selectedStage) {
      stageError.classList.remove('hidden');
      return;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';

    try {
      const visitDate = (document.getElementById('modal-visit-date') as HTMLInputElement).value;
      const notes = (document.getElementById('modal-notes') as HTMLTextAreaElement).value;

      const res = await fetch('/api/project82', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          province_key: currentProvince.province_key,
          stage: selectedStage,
          visit_date: visitDate || null,
          notes: notes || null,
        }),
      });

      if (!res.ok) throw new Error(await res.text());

      const { visit } = await res.json();
      window.dispatchEvent(new CustomEvent('province-visit-saved', {
        detail: {
          province_key: currentProvince.province_key,
          stage: selectedStage,
          isNew: !isExisting,
          visit,
        },
      }));
      dialog.close();
    } catch (err) {
      console.error('Failed to save visit:', err);
      saveBtn.textContent = 'Error — try again';
      saveBtn.disabled = false;
    }
  });

  deleteBtn.addEventListener('click', async () => {
    if (!currentProvince || !isExisting) return;
    if (!confirm(`Remove your visit to ${currentProvince.province_name}?`)) return;

    deleteBtn.disabled = true;
    try {
      const res = await fetch(`/api/project82/${currentProvince.province_key}`, { method: 'DELETE' });
      if (!res.ok) throw new Error(await res.text());

      window.dispatchEvent(new CustomEvent('province-visit-deleted', {
        detail: { province_key: currentProvince.province_key },
      }));
      dialog.close();
    } catch (err) {
      console.error('Failed to delete visit:', err);
      deleteBtn.disabled = false;
    }
  });
</script>
