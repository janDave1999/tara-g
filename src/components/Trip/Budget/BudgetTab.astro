---
interface Props {
  tripId: string;
  isOwner: boolean;
  userId?: string;
  costSharingMethod?: string;
  budgetEstimate?: number;
  poolEnabled?: boolean;
  poolPerPerson?: number;
  allowMembersToLog?: boolean;
}

const {
  tripId,
  isOwner,
  userId,
  costSharingMethod = 'split_evenly',
  budgetEstimate,
  poolEnabled = false,
  poolPerPerson,
  allowMembersToLog = true,
} = Astro.props;

const canAddExpense = isOwner || (allowMembersToLog && costSharingMethod !== 'organizer_shoulders_all');

// Adaptive section flags (server-side)
const showBudgetBar    = budgetEstimate && costSharingMethod !== 'event_fee' && costSharingMethod !== 'budget_pool';
const showFeeSection   = costSharingMethod === 'event_fee';
const showPoolSection  = costSharingMethod === 'budget_pool';
const showMemberBal    = ['split_evenly', 'custom_split', 'event_fee', 'budget_pool'].includes(costSharingMethod);

const costSharingLabels: Record<string, string> = {
  split_evenly:            'Split Evenly',
  organizer_shoulders_all: 'Organizer Shoulders All',
  everyone_pays_own:       'Everyone Pays Own',
  custom_split:            'Custom Split',
  event_fee:               'Event Fee',
  budget_pool:             'Budget Pool',
};

const costSharingIcons: Record<string, string> = {
  split_evenly:            '⚖️',
  organizer_shoulders_all: '🤝',
  everyone_pays_own:       '👤',
  custom_split:            '✏️',
  event_fee:               '🎟️',
  budget_pool:             '🏦',
};

const costSharingOptions = [
  { value: 'split_evenly',            label: 'Split Evenly' },
  { value: 'organizer_shoulders_all', label: 'Organizer Shoulders All' },
  { value: 'everyone_pays_own',       label: 'Everyone Pays Own' },
  { value: 'custom_split',            label: 'Custom Split' },
  { value: 'event_fee',               label: 'Event Fee (fixed fee per person)' },
  { value: 'budget_pool',             label: 'Budget Pool (shared fund)' },
];
---

<div
  class="budget-container"
  data-trip-id={tripId}
  data-is-owner={isOwner}
  data-user-id={userId}
  data-cost-sharing={costSharingMethod}
  data-budget-estimate={budgetEstimate || 0}
>

  <!-- Header -->
  <div class="flex items-center justify-between gap-3 mb-5 px-1">
    <div>
      <h2 class="text-lg font-bold text-gray-900">Budget & Expenses</h2>
      <span class="text-xs text-gray-400 font-medium">
        {costSharingIcons[costSharingMethod]} {costSharingLabels[costSharingMethod] || costSharingMethod}
      </span>
    </div>
    <div class="flex gap-2 shrink-0">
      {isOwner && (
        <button id="budget-settings-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 border border-gray-200 text-sm font-medium transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Settings
        </button>
      )}
      {canAddExpense && (
        <button id="add-expense-btn" class="flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
          </svg>
          Add Expense
        </button>
      )}
    </div>
  </div>

  <!-- Expense Summary (standard methods: split_evenly, custom_split, etc.) -->
  {!showFeeSection && !showPoolSection && (
    <div class="mb-4 bg-white rounded-xl p-4 border border-gray-100">
      <div class="flex items-start justify-between gap-3 mb-1">
        <div>
          <p class="text-xs text-gray-400 mb-0.5">Total Spent</p>
          <p class="text-3xl font-bold text-gray-900 tabular-nums" id="hero-spent">₱0</p>
        </div>
        <div id="per-person-badge" class="hidden text-right shrink-0">
          <p class="text-xs text-gray-400 mb-0.5">Per Person</p>
          <p class="text-sm font-bold text-gray-500 tabular-nums" id="per-person-amount">—</p>
        </div>
      </div>

      <!-- Budget bar — shown by JS when budget estimate is set -->
      <div id="budget-bar-section" class="hidden mt-3 pt-3 border-t border-gray-50">
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-xs text-gray-400" id="budget-bar-label">Budget</span>
          <span class="text-xs font-bold tabular-nums" id="budget-bar-pct">0%</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
          <div id="budget-progress-bar" class="h-2 rounded-full bg-blue-500 transition-all duration-500" style="width: 0%"></div>
        </div>
        <p class="text-xs font-semibold mt-1.5" id="budget-status-line"></p>
      </div>

      <!-- No budget set hint — shown by JS when no estimate -->
      <div id="no-budget-hint" class="hidden mt-3 pt-3 border-t border-gray-50">
        <p class="text-xs text-gray-300">
          No budget estimate set
          {isOwner && (
            <> · <button type="button" id="set-budget-shortcut" class="text-gray-400 hover:text-blue-500 transition-colors">Set one →</button></>
          )}
        </p>
      </div>
    </div>
  )}

  <!-- Collection Summary (event_fee / budget_pool) -->
  {(showFeeSection || showPoolSection) && (
    <div class={`grid grid-cols-2 gap-2 ${showPoolSection ? 'mb-2' : 'mb-4'}`}>
      <div class="bg-white rounded-xl p-3 border border-gray-100">
        <p class="text-xs text-gray-400 mb-1">{showFeeSection ? 'Fees Collected' : 'Pool Collected'}</p>
        <p class="text-xl font-bold text-gray-900 tabular-nums" id="pool-collected">₱0</p>
        <p class="text-xs text-gray-500 mt-0.5" id="collected-sub">—</p>
      </div>
      <div class="bg-white rounded-xl p-3 border border-gray-100">
        <p class="text-xs text-gray-400 mb-1">Still Pending</p>
        <p class="text-xl font-bold tabular-nums text-gray-300" id="pool-pending">—</p>
        <p class="text-xs mt-0.5" id="pending-sub">—</p>
      </div>
    </div>
  )}

  <!-- Pool Balance Card (budget_pool only — updated by JS) -->
  {showPoolSection && (
    <div id="pool-balance-card" class="hidden mb-4 bg-white rounded-xl p-3 border border-blue-100">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-xs text-blue-400 mb-0.5">Available Balance</p>
          <p class="text-xl font-bold tabular-nums" id="pool-balance-amount">—</p>
          <p class="text-xs mt-0.5" id="pool-balance-sub">—</p>
        </div>
        <div class="text-right shrink-0">
          <p class="text-xs text-gray-400 mb-0.5">Spent from Pool</p>
          <p class="text-sm font-bold text-gray-500 tabular-nums" id="pool-spent-amount">—</p>
        </div>
      </div>
    </div>
  )}

  <!-- Fee Collection Section (event_fee only) -->
  {showFeeSection && (
    <div class="mb-4 bg-white rounded-xl border border-gray-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-50">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-bold text-gray-800">Fee Collection</h3>
          <span id="fee-summary-badge" class="text-xs font-semibold text-gray-400"></span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div id="fee-collection-bar" class="h-1.5 rounded-full bg-blue-500 transition-all duration-500" style="width:0%"></div>
        </div>
        <p id="fee-collection-status" class="text-xs text-gray-400 mt-1.5"></p>
      </div>
      <div id="fee-collection-body">
        <div class="px-4 py-6 text-center text-sm text-gray-400">Loading...</div>
      </div>
    </div>
  )}

  <!-- Pool Contributions Section (budget_pool only) -->
  {showPoolSection && (
    <div class="mb-4 bg-white rounded-xl border border-gray-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-50">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-bold text-gray-800">Pool Contributions</h3>
          <span id="pool-summary-badge" class="text-xs font-semibold text-gray-400"></span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
          <div id="pool-collection-bar" class="h-1.5 rounded-full bg-blue-500 transition-all duration-500" style="width:0%"></div>
        </div>
        <p id="pool-collection-status" class="text-xs text-gray-400 mt-1.5"></p>
      </div>
      <div id="pool-contributions-body">
        <div class="px-4 py-6 text-center text-sm text-gray-400">Loading...</div>
      </div>
    </div>
  )}

  <!-- Member Balances (split_evenly, custom_split, event_fee, budget_pool) -->
  {showMemberBal && (
    <div class="mb-4 bg-white rounded-xl border border-gray-100 overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-50 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-800">
          {showFeeSection || showPoolSection ? 'Expense Balances' : 'Member Balances'}
        </h3>
        {!showFeeSection && !showPoolSection && (
          <span class="text-xs text-gray-400">tap owes to settle</span>
        )}
      </div>
      <div id="member-balances-body">
        <div class="px-4 py-6 text-center text-sm text-gray-400">Loading...</div>
      </div>
    </div>
  )}

  <!-- Pending Refunds (shown by JS when non-pool method has paid contributions) -->
  <div id="pending-refunds-section" class="hidden mb-4 bg-white rounded-xl border border-red-100 overflow-hidden">
    <div class="px-4 py-3 border-b border-red-50 flex items-center justify-between">
      <div>
        <h3 class="text-sm font-bold text-gray-800">Pending Refunds</h3>
        <p class="text-xs text-gray-400">Members who paid into the previous pool</p>
      </div>
      <span id="refunds-badge" class="text-xs font-semibold text-red-500"></span>
    </div>
    <div id="pending-refunds-body">
      <div class="px-4 py-6 text-center text-sm text-gray-400">Loading...</div>
    </div>
  </div>

  <!-- Expenses List (always) -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-50">
      <h3 class="text-sm font-bold text-gray-800">Expenses</h3>
    </div>
    <div id="expenses-body">
      <div class="px-4 py-6 text-center text-sm text-gray-400">No expenses yet</div>
    </div>
  </div>

  <!-- Transaction Log -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <button id="txlog-toggle" class="w-full flex items-center justify-between px-4 py-3 border-b border-gray-50 hover:bg-gray-50 transition-colors">
      <div class="flex items-center gap-2">
        <h3 class="text-sm font-bold text-gray-800">Transaction Log</h3>
        <span id="txlog-badge" class="hidden text-xs px-1.5 py-0.5 rounded-full bg-gray-100 text-gray-500 font-medium tabular-nums"></span>
      </div>
      <svg id="txlog-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <div id="txlog-body" class="hidden">
      <div class="px-4 py-6 text-center text-sm text-gray-400">Loading…</div>
    </div>
  </div>

</div>

<!-- Add Expense Modal -->
<dialog id="expense-modal" class="modal">
  <div class="modal-box max-w-sm rounded-2xl p-0 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h3 class="font-bold text-base text-gray-900">Add Expense</h3>
    </div>
    <form id="expense-form" class="p-5 space-y-3">
      <input type="hidden" name="tripId" value={tripId} />

      <div>
        <label class="block text-xs font-semibold text-gray-600 mb-1">Amount (₱) *</label>
        <input type="number" name="amount" step="0.01" min="0.01" required placeholder="0.00"
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-600 mb-1">Description *</label>
        <input type="text" name="description" required placeholder="What was this for?"
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">Category *</label>
          <select name="category" required
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none bg-white">
            <option value="accommodation">🏨 Accommodation</option>
            <option value="food">🍜 Food</option>
            <option value="transport">🚌 Transport</option>
            <option value="activities">🎡 Activities</option>
            <option value="misc">📦 Miscellaneous</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">Date *</label>
          <input type="date" name="date" required
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
        </div>
      </div>

      <div id="payer-select-group">
        <label class="block text-xs font-semibold text-gray-600 mb-1">Who Paid? *</label>
        <select name="payerId" id="payer-select"
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none bg-white">
          <option value="">Select who paid</option>
        </select>
      </div>

      <!-- Payment Source (budget_pool only) -->
      <div id="payment-source-group" class="hidden">
        <label class="block text-xs font-semibold text-gray-600 mb-1.5">Payment Source</label>
        <div class="flex gap-2">
          <label id="ps-personal-label" class="flex-1 flex items-center gap-2 p-2.5 border-2 border-blue-500 bg-blue-50 rounded-lg cursor-pointer transition-colors">
            <input type="radio" name="paymentSource" value="personal" class="accent-blue-600" checked />
            <div>
              <p class="text-xs font-semibold text-gray-700">Personal</p>
              <p class="text-[10px] text-gray-400">Someone paid out of pocket</p>
            </div>
          </label>
          <label id="ps-pool-label" class="flex-1 flex items-center gap-2 p-2.5 border-2 border-gray-200 rounded-lg cursor-pointer transition-colors">
            <input type="radio" name="paymentSource" value="pool" class="accent-blue-600" />
            <div>
              <p class="text-xs font-semibold text-gray-700">From Pool</p>
              <p class="text-[10px] text-gray-400">Paid from shared funds</p>
            </div>
          </label>
        </div>
      </div>

      <!-- Covered members picker -->
      <div id="covered-members-section">
        <div class="flex items-center justify-between mb-1.5">
          <label class="text-xs font-semibold text-gray-600">Covered Members *</label>
          <div class="flex items-center gap-2">
            <span id="per-person-calc" class="text-xs text-blue-600 font-semibold"></span>
            <button type="button" id="select-all-members" class="text-xs text-gray-400 hover:text-blue-600 font-medium transition-colors">All</button>
            <span class="text-gray-200">|</span>
            <button type="button" id="unselect-all-members" class="text-xs text-gray-400 hover:text-red-500 font-medium transition-colors">None</button>
          </div>
        </div>
        <div id="member-checkboxes" class="space-y-1 max-h-36 overflow-y-auto border border-gray-100 rounded-lg p-2 bg-gray-50">
          <p class="text-xs text-gray-400 text-center py-2">Loading members…</p>
        </div>
        <p class="text-xs text-gray-400 mt-1">Payer's share is deducted automatically. Others will owe them.</p>
      </div>

      <div class="flex gap-2 pt-2 border-t border-gray-100">
        <button type="button" class="flex-1 px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
          onclick="document.getElementById('expense-modal').close()">Cancel</button>
        <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors">
          Add Expense
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Budget Settings Modal -->
<dialog id="budget-settings-modal" class="modal">
  <div class="modal-box max-w-sm rounded-2xl p-0 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h3 class="font-bold text-base text-gray-900">Budget Settings</h3>
    </div>
    <form id="budget-settings-form" class="p-5 space-y-3">
      <input type="hidden" name="tripId" value={tripId} />

      <div>
        <label class="block text-xs font-semibold text-gray-600 mb-1">Cost Sharing Method</label>
        <select name="costSharingMethod" id="settings-method-select" required
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none bg-white">
          {costSharingOptions.map(opt => (
            <option value={opt.value} selected={costSharingMethod === opt.value}>{opt.label}</option>
          ))}
        </select>
      </div>

      <!-- Method-change reconciliation warnings (rendered by JS) -->
      <div id="method-change-warnings" class="hidden space-y-3"></div>

      <!-- Per-person amount: shown for event_fee and budget_pool -->
      <div id="per-person-group" class={`${costSharingMethod === 'event_fee' || costSharingMethod === 'budget_pool' ? '' : 'hidden'}`}>
        <label class="block text-xs font-semibold text-gray-600 mb-1" id="per-person-label">
          {costSharingMethod === 'event_fee' ? 'Fee per Person (₱)' : 'Target per Person (₱)'}
        </label>
        <input type="number" name="poolPerPerson" step="0.01" min="0"
          value={poolPerPerson || ''}
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
        <p class="text-xs text-gray-400 mt-1" id="per-person-hint">
          {costSharingMethod === 'event_fee'
            ? 'Auto-charged when a member joins.'
            : 'How much each member contributes to the pool.'}
        </p>
      </div>

      <!-- Budget estimate: hidden for event_fee / budget_pool -->
      <div id="budget-estimate-group" class={`${costSharingMethod === 'event_fee' || costSharingMethod === 'budget_pool' ? 'hidden' : ''}`}>
        <label class="block text-xs font-semibold text-gray-600 mb-1">Budget Estimate (₱)</label>
        <input type="number" name="budgetEstimate" step="0.01" min="0" placeholder="Optional"
          value={budgetEstimate || ''}
          class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>

      <div class="flex gap-2 pt-2 border-t border-gray-100">
        <button type="button" class="flex-1 px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
          onclick="document.getElementById('budget-settings-modal').close()">Cancel</button>
        <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors">
          Save Settings
        </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<!-- Member Owes Modal -->
<dialog id="owes-modal" class="modal">
  <div class="modal-box max-w-sm rounded-2xl p-0 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="font-bold text-base text-gray-900" id="owes-modal-title">Owes Details</h3>
      <button type="button" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
        onclick="document.getElementById('owes-modal').close()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="owes-modal-content" class="p-5">
      <p class="text-sm text-gray-400 text-center py-4">Loading...</p>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  import { actions } from 'astro:actions';
  import { showToast } from '@/scripts/Toast';
  import { showConfirmModal } from '@/scripts/NewModal';
  import { PUBLIC_R2_URL } from 'astro:env/client';

  const container = document.querySelector('.budget-container') as HTMLElement;
  const tripId = container?.dataset.tripId;
  const isOwner = container?.dataset.isOwner === 'true';
  const costSharing = container?.dataset.costSharing || 'split_evenly';
  const budgetEstimate = parseFloat(container?.dataset.budgetEstimate || '0') || 0;

  // Wire up "Set one →" shortcut to open settings modal
  document.getElementById('set-budget-shortcut')?.addEventListener('click', () => {
    (document.getElementById('budget-settings-modal') as HTMLDialogElement)?.showModal();
  });

  const CATEGORY_COLORS: Record<string, { bar: string; text: string; bg: string }> = {
    accommodation: { bar: 'bg-purple-400', text: 'text-purple-600', bg: 'bg-purple-50' },
    food:          { bar: 'bg-orange-400', text: 'text-orange-600', bg: 'bg-orange-50' },
    transport:     { bar: 'bg-blue-400',   text: 'text-blue-600',   bg: 'bg-blue-50' },
    activities:    { bar: 'bg-green-400',  text: 'text-green-600',  bg: 'bg-green-50' },
    misc:          { bar: 'bg-gray-400',   text: 'text-gray-500',   bg: 'bg-gray-50' },
  };

  const AVATAR_COLORS = [
    'bg-blue-100 text-blue-700',
    'bg-purple-100 text-purple-700',
    'bg-green-100 text-green-700',
    'bg-amber-100 text-amber-700',
    'bg-rose-100 text-rose-700',
    'bg-cyan-100 text-cyan-700',
  ];

  const initials = (name: string) =>
    name.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();

  /** Renders a circular avatar: photo if available, initials fallback. */
  function avatarEl(avatarUrl: string | null | undefined, name: string, colorClass: string, size = 'w-9 h-9'): string {
    const url = avatarUrl
      ? (avatarUrl.startsWith('http') ? avatarUrl : `${PUBLIC_R2_URL}${avatarUrl}`)
      : null;
    if (url) {
      return `
        <div class="${size} rounded-full overflow-hidden shrink-0 bg-gray-100">
          <img src="${url}" alt="${name}" class="w-full h-full object-cover"
            onerror="this.parentElement.innerHTML='<span class=\\'w-full h-full ${colorClass} flex items-center justify-center text-xs font-bold\\'>${initials(name)}</span>'" />
        </div>`;
    }
    return `<div class="${size} rounded-full ${colorClass} flex items-center justify-center text-xs font-bold shrink-0">${initials(name)}</div>`;
  }

  let currentMembers: Array<{ id: string; name: string }> = [];

  // ── Data loaders ────────────────────────────────────────────────────────────

  async function loadData() {
    if (!tripId) return;
    const timeout = new Promise<never>((_, reject) =>
      setTimeout(() => reject(new Error('Load timeout')), 8000)
    );
    const loaders: Promise<any>[] = [loadExpenses()];

    if (costSharing === 'event_fee') {
      loaders.push(loadFeeCollection());
    } else if (costSharing === 'budget_pool') {
      loaders.push(loadPoolContributions());
    } else {
      // Non-pool method: check for paid contributions that still need refunding
      loaders.push(loadPendingRefunds());
    }

    if (['split_evenly', 'custom_split', 'event_fee', 'budget_pool'].includes(costSharing)) {
      loaders.push(loadMemberBalances());
    }

    try {
      await Promise.race([Promise.all(loaders), timeout]);
    } catch (e) {
      console.error('Budget data load failed:', e);
      showToast({ message: 'Failed to load budget data. Please refresh.', type: 'error' });
    }
  }

  async function loadExpenses() {
    if (!tripId) return;
    try {
      const result = await actions.budget.getExpenses({ tripId });
      const expenses = Array.isArray(result) ? result : (result?.data || []);
      const body = document.getElementById('expenses-body')!;
      if (!body) return;

      if (expenses.length === 0) {
        body.innerHTML = `<div class="px-4 py-8 text-center text-sm text-gray-400">No expenses yet</div>`;
        updateSummaryFromExpenses(0);
        return;
      }

      body.innerHTML = expenses.map((exp: any) => {
        const cat = CATEGORY_COLORS[exp.category] ?? CATEGORY_COLORS.misc;
        const date = new Date(exp.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const fromPool = exp.paid_from_pool === true;
        return `
          <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-50 last:border-b-0 hover:bg-gray-50/50 transition-colors expense-row" data-expense-id="${exp.id}">
            <div class="w-1 self-stretch rounded-full ${cat.bar} shrink-0"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate">${exp.description || '—'}</p>
              <p class="text-xs text-gray-400">${date} · ${fromPool ? '🏦 Pool' : exp.payer_name}</p>
            </div>
            <div class="text-right shrink-0">
              <p class="text-sm font-bold text-gray-900">₱${parseFloat(exp.amount).toLocaleString()}</p>
              <span class="text-xs font-medium ${fromPool ? 'text-blue-500' : cat.text}">${fromPool ? 'from pool' : exp.category}</span>
            </div>
            ${isOwner ? `
              <button class="delete-expense-btn p-1.5 text-gray-300 hover:text-red-400 hover:bg-red-50 rounded-lg transition-colors ml-1" data-expense-id="${exp.id}" title="Delete">
                <svg class="w-3.5 h-3.5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>` : ''}
          </div>
        `;
      }).join('');

      const total = expenses.reduce((sum: number, exp: any) => sum + parseFloat(exp.amount), 0);
      updateSummaryFromExpenses(total);

      body.querySelectorAll('.delete-expense-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const expenseId = (e.currentTarget as HTMLElement).dataset.expenseId;
          if (!expenseId) return;
          const confirmed = await showConfirmModal({
            title: 'Delete Expense',
            message: 'This expense and its splits will be permanently removed.',
            confirmText: 'Delete',
            confirmVariant: 'danger',
          });
          if (confirmed) {
            const result = await actions.budget.deleteExpense({ expenseId, tripId: tripId! });
            if (!(result as any).error) {
              showToast({ message: 'Expense deleted', type: 'success' });
              loadData();
            }
          }
        });
      });
    } catch (e) {
      console.error('Error loading expenses:', e);
    }
  }

  function updateSummaryFromExpenses(total: number) {
    if (costSharing === 'event_fee' || costSharing === 'budget_pool') return;

    const heroEl = document.getElementById('hero-spent');
    if (heroEl) heroEl.textContent = `₱${total.toLocaleString()}`;

    const barSection   = document.getElementById('budget-bar-section');
    const noBudgetHint = document.getElementById('no-budget-hint');
    const progressBar  = document.getElementById('budget-progress-bar') as HTMLElement;
    const barPct       = document.getElementById('budget-bar-pct');
    const barLabel     = document.getElementById('budget-bar-label');
    const statusLine   = document.getElementById('budget-status-line');

    if (budgetEstimate > 0) {
      barSection?.classList.remove('hidden');
      noBudgetHint?.classList.add('hidden');

      const rawPct  = total / budgetEstimate * 100;
      const dispPct = Math.min(rawPct, 100); // bar is capped — percentage text is real
      const isOver  = total > budgetEstimate;
      const isNear  = rawPct >= 80 && !isOver;

      if (progressBar) {
        progressBar.style.width = `${dispPct}%`;
        progressBar.className = `h-2 rounded-full transition-all duration-500 ${
          isOver ? 'bg-red-500' : isNear ? 'bg-amber-400' : 'bg-blue-500'
        }`;
      }
      if (barLabel) barLabel.textContent = `vs ₱${budgetEstimate.toLocaleString()} budget`;
      if (barPct) {
        barPct.textContent = `${rawPct.toFixed(0)}%`;
        barPct.className = `text-xs font-bold tabular-nums ${isOver ? 'text-red-500' : isNear ? 'text-amber-500' : 'text-gray-500'}`;
      }
      if (statusLine) {
        if (isOver) {
          const over = total - budgetEstimate;
          statusLine.textContent = `₱${over.toLocaleString()} over budget`;
          statusLine.className = 'text-xs font-semibold mt-1.5 text-red-500';
        } else if (isNear) {
          const left = budgetEstimate - total;
          statusLine.textContent = `₱${left.toLocaleString()} left — approaching limit`;
          statusLine.className = 'text-xs font-semibold mt-1.5 text-amber-500';
        } else {
          const left = budgetEstimate - total;
          statusLine.textContent = total === 0 ? '' : `₱${left.toLocaleString()} remaining`;
          statusLine.className = 'text-xs font-semibold mt-1.5 text-green-500';
        }
      }
    } else {
      barSection?.classList.add('hidden');
      noBudgetHint?.classList.remove('hidden');
    }
  }

  function renderContribRow(c: any, i: number, isFeeSemantic: boolean, refundableAmount?: number): string {
    const avatarColor = AVATAR_COLORS[i % AVATAR_COLORS.length];
    const amount     = parseFloat(c.amount) || 0;
    const amountPaid = parseFloat(c.amount_paid ?? 0) || 0;
    const remaining  = Math.max(amount - amountPaid, 0);
    const pct        = amount > 0 ? Math.min((amountPaid / amount) * 100, 100) : 0;
    const paid       = c.status === 'paid';
    const partial    = c.status === 'partial';
    const refunded   = c.status === 'refunded';

    // Show refundable hint when: paid pool member, refundable > 0 (pool has remaining balance),
    // and refundable differs from amount paid (i.e. something was spent from pool)
    const showRefundable = paid && !refunded && !isFeeSemantic
      && refundableAmount !== undefined
      && refundableAmount > 0
      && Math.abs(refundableAmount - amountPaid) > 0.009;

    const statusText = refunded
      ? `<span class="text-gray-400">↩ Refunded</span>`
      : paid
        ? `<span class="text-green-500">✓ ${isFeeSemantic ? 'Fee paid' : 'Contributed'}</span>${showRefundable ? ` · <span class="text-blue-500 text-xs">est. refund ₱${refundableAmount!.toLocaleString()}</span>` : ''}`
        : partial
          ? `<span class="text-blue-500">₱${amountPaid.toLocaleString()} paid · <span class="text-amber-500">₱${remaining.toLocaleString()} left</span></span>`
          : `<span class="text-amber-500">₱${amount.toLocaleString()} ${isFeeSemantic ? 'due' : 'pending'}</span>`;

    const progressBar = !paid && !refunded
      ? `<div class="w-full bg-gray-100 rounded-full h-1 mt-1 overflow-hidden">
           <div class="h-1 rounded-full ${partial ? 'bg-blue-400' : 'bg-gray-200'} transition-all" style="width:${pct}%"></div>
         </div>`
      : '';

    const paymentBtns = isOwner && !paid && !refunded
      ? `<div class="payment-action-area flex items-center gap-1.5 shrink-0">
           <button class="pay-full-btn text-xs px-2 py-1 rounded-lg bg-green-50 border border-green-200 text-green-700 hover:bg-green-100 font-semibold transition-colors"
             data-contribution-id="${c.id}" data-user-name="${c.user_name}" data-amount="${amount}">
             Full
           </button>
           <button class="pay-partial-btn text-xs px-2 py-1 rounded-lg bg-blue-50 border border-blue-200 text-blue-700 hover:bg-blue-100 font-semibold transition-colors"
             data-contribution-id="${c.id}" data-user-name="${c.user_name}" data-amount="${amount}" data-remaining="${remaining}">
             Partial
           </button>
         </div>`
      // Show "Mark Refunded" only when there's something to refund:
      //   - refundableAmount undefined → non-pool context (pending-refunds section), always show
      //   - refundableAmount > 0       → pool has remaining balance, show
      //   - refundableAmount === 0     → pool fully spent, nothing to refund, hide
      : isOwner && paid && (refundableAmount === undefined || refundableAmount > 0)
        ? `<div class="payment-action-area flex items-center gap-1.5 shrink-0">
             <button class="mark-refunded-btn text-xs px-2 py-1 rounded-lg bg-gray-50 border border-gray-200 text-gray-500 hover:bg-gray-100 font-semibold transition-colors"
               data-contribution-id="${c.id}" data-user-name="${c.user_name}" data-amount="${refundableAmount !== undefined ? refundableAmount : amountPaid}">
               Mark Refunded
             </button>
           </div>`
        : '';

    return `
      <div class="px-4 py-3 border-b border-gray-50 last:border-b-0 contribution-row" data-contribution-id="${c.id}">
        <div class="flex items-center gap-3">
          ${avatarEl(c.avatar_url, c.user_name || '?', avatarColor)}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-gray-900 truncate">${c.user_name || '—'}</p>
            <p class="text-xs font-medium">${statusText}</p>
            ${progressBar}
          </div>
          <div class="flex items-center gap-2 shrink-0">
            ${paymentBtns}
            <span class="text-sm font-bold tabular-nums ${paid ? 'text-green-600' : partial ? 'text-blue-600' : 'text-gray-300'}">
              ₱${amount.toLocaleString()}
            </span>
          </div>
        </div>
      </div>
    `;
  }

  // Effective paid: if status='paid' but amount_paid=0 (legacy rows marked with old RPC),
  // treat the full amount as paid.
  const effectivePaid = (c: any) => {
    const ap = parseFloat(c.amount_paid ?? 0) || 0;
    return c.status === 'paid' && ap === 0 ? (parseFloat(c.amount) || 0) : ap;
  };

  function updateContribSummary(
    contribs: any[],
    badgeId: string,
    badgeLabel: string,
    barId: string,
    statusId: string,
  ) {
    const totalExpected  = contribs.reduce((s: number, c: any) => s + (parseFloat(c.amount) || 0), 0);
    const totalCollected = contribs.reduce((s: number, c: any) => s + effectivePaid(c), 0);
    const totalPending   = Math.max(totalExpected - totalCollected, 0);
    const paidFull       = contribs.filter((c: any) => c.status === 'paid').length;
    const pct            = totalExpected > 0 ? Math.min((totalCollected / totalExpected) * 100, 100) : 0;
    const allPaid        = paidFull === contribs.length && contribs.length > 0;

    // Badge (inside the fee/pool section header)
    const badge = document.getElementById(badgeId);
    if (badge) badge.textContent = `${paidFull}/${contribs.length} ${badgeLabel}`;

    // Collection summary cards (pool / fee methods)
    const collectedEl = document.getElementById('pool-collected');
    if (collectedEl) collectedEl.textContent = `₱${totalCollected.toLocaleString()}`;

    const collectedSub = document.getElementById('collected-sub');
    if (collectedSub) {
      collectedSub.textContent = allPaid
        ? `All ${contribs.length} paid ✓`
        : `${paidFull} of ${contribs.length} paid`;
      collectedSub.className = `text-xs mt-0.5 font-medium ${allPaid ? 'text-green-500' : 'text-gray-400'}`;
    }

    const pendingEl = document.getElementById('pool-pending');
    if (pendingEl) {
      pendingEl.textContent = totalPending > 0 ? `₱${totalPending.toLocaleString()}` : '—';
      pendingEl.className = `text-xl font-bold tabular-nums ${totalPending > 0 ? 'text-amber-500' : 'text-green-600'}`;
    }

    const pendingSub = document.getElementById('pending-sub');
    if (pendingSub) {
      const pendingCount = contribs.filter((c: any) => c.status !== 'paid' && c.status !== 'refunded').length;
      pendingSub.textContent = pendingCount > 0
        ? `${pendingCount} member${pendingCount > 1 ? 's' : ''} outstanding`
        : allPaid ? 'Fully collected' : '—';
      pendingSub.className = `text-xs mt-0.5 font-medium ${pendingCount > 0 ? 'text-amber-500' : 'text-green-500'}`;
    }

    // Section progress bar
    const bar = document.getElementById(barId) as HTMLElement;
    if (bar) {
      bar.style.width = `${pct}%`;
      bar.className = `h-1.5 rounded-full transition-all duration-500 ${allPaid ? 'bg-green-500' : 'bg-blue-500'}`;
    }

    const statusEl = document.getElementById(statusId);
    if (statusEl) {
      statusEl.textContent = allPaid
        ? `All collected — ₱${totalCollected.toLocaleString()} total`
        : `₱${totalCollected.toLocaleString()} of ₱${totalExpected.toLocaleString()} collected (${pct.toFixed(0)}%)`;
      statusEl.className = `text-xs mt-1.5 font-medium ${allPaid ? 'text-green-500' : 'text-gray-400'}`;
    }
  }

  async function loadFeeCollection() {
    if (!tripId) return;
    try {
      const res = await actions.budget.getPoolContributions({ tripId });
      const contribs: any[] = Array.isArray(res) ? res : (res?.data || []);
      const body = document.getElementById('fee-collection-body')!;
      if (!body) return;

      if (contribs.length === 0) {
        body.innerHTML = `<div class="px-4 py-6 text-center text-sm text-gray-400">No members yet</div>`;
        return;
      }

      updateContribSummary(contribs, 'fee-summary-badge', 'paid', 'fee-collection-bar', 'fee-collection-status');
      body.innerHTML = contribs.map((c, i) => renderContribRow(c, i, true)).join('');
      setupPaymentHandlers(body, loadFeeCollection);
    } catch (e) {
      console.error('Error loading fee collection:', e);
    }
  }

  async function loadPoolContributions() {
    if (!tripId) return;
    try {
      const [contribRes, balanceRes] = await Promise.all([
        actions.budget.getPoolContributions({ tripId }),
        actions.budget.getPoolBalance({ tripId }),
      ]);

      const contribs: any[] = Array.isArray(contribRes) ? contribRes : (contribRes?.data || []);
      const balance = (balanceRes as any)?.data ?? balanceRes;

      const body = document.getElementById('pool-contributions-body')!;
      if (!body) return;

      // Update pool balance card
      const balanceCard = document.getElementById('pool-balance-card');
      const balanceAmountEl = document.getElementById('pool-balance-amount');
      const balanceSubEl = document.getElementById('pool-balance-sub');
      const spentEl = document.getElementById('pool-spent-amount');

      if (balance && (balance.collected > 0 || balance.spent > 0)) {
        balanceCard?.classList.remove('hidden');
        const bal = parseFloat(balance.balance) || 0;
        const spent = parseFloat(balance.spent) || 0;
        const collected = parseFloat(balance.collected) || 0;
        const overdrawn = bal < 0;

        // Card border: red when overdrawn, blue otherwise
        if (balanceCard) {
          balanceCard.classList.toggle('border-red-200', overdrawn);
          balanceCard.classList.toggle('border-blue-100', !overdrawn);
        }

        if (balanceAmountEl) {
          if (overdrawn) {
            balanceAmountEl.textContent = `−₱${Math.abs(bal).toLocaleString()}`;
            balanceAmountEl.className = 'text-xl font-bold tabular-nums text-red-600';
          } else {
            balanceAmountEl.textContent = `₱${bal.toLocaleString()}`;
            balanceAmountEl.className = `text-xl font-bold tabular-nums ${bal === 0 ? 'text-gray-400' : 'text-blue-700'}`;
          }
        }

        const labelEl = balanceCard?.querySelector('p.text-xs.text-blue-400');
        if (labelEl) {
          labelEl.textContent = overdrawn ? 'Pool Overdrawn' : 'Available Balance';
          labelEl.className = `text-xs mb-0.5 ${overdrawn ? 'text-red-400' : 'text-blue-400'}`;
        }

        if (balanceSubEl) {
          if (overdrawn) {
            balanceSubEl.textContent = `Overdrawn by ₱${Math.abs(bal).toLocaleString()} · consider topping up`;
            balanceSubEl.className = 'text-xs mt-0.5 text-red-400';
          } else {
            balanceSubEl.textContent = spent > 0
              ? `₱${collected.toLocaleString()} collected · ₱${spent.toLocaleString()} used`
              : 'No pool expenses yet';
            balanceSubEl.className = `text-xs mt-0.5 ${spent > 0 ? 'text-gray-400' : 'text-gray-300'}`;
          }
        }
        if (spentEl) {
          spentEl.textContent = spent > 0 ? `₱${spent.toLocaleString()}` : '—';
        }
      } else {
        balanceCard?.classList.add('hidden');
      }

      // Build auth_id → refundable map for per-member display
      const refundableMap: Record<string, number> = {};
      if (balance?.members) {
        for (const m of balance.members) {
          refundableMap[m.auth_id] = parseFloat(m.refundable) || 0;
        }
      }

      if (contribs.length === 0) {
        body.innerHTML = `<div class="px-4 py-6 text-center text-sm text-gray-400">No members yet</div>`;
        return;
      }

      updateContribSummary(contribs, 'pool-summary-badge', 'contributed', 'pool-collection-bar', 'pool-collection-status');
      body.innerHTML = contribs.map((c, i) => renderContribRow(c, i, false, refundableMap[c.user_id])).join('');
      setupPaymentHandlers(body, loadPoolContributions);
    } catch (e) {
      console.error('Error loading pool contributions:', e);
    }
  }

  async function loadPendingRefunds() {
    if (!tripId) return;
    try {
      const res = await actions.budget.getPoolContributions({ tripId });
      const contribs: any[] = Array.isArray(res) ? res : (res?.data || []);
      const paid = contribs.filter(c => c.status === 'paid');

      const section = document.getElementById('pending-refunds-section');
      const body = document.getElementById('pending-refunds-body');
      const badge = document.getElementById('refunds-badge');
      if (!section || !body) return;

      if (paid.length === 0) {
        section.classList.add('hidden');
        return;
      }

      section.classList.remove('hidden');
      if (badge) badge.textContent = `${paid.length} pending`;

      body.innerHTML = paid.map((c, i) => renderContribRow(c, i, false)).join('');
      setupPaymentHandlers(body, loadPendingRefunds);
    } catch (e) {
      console.error('Error loading pending refunds:', e);
    }
  }

  async function loadMemberBalances() {
    if (!tripId) return;
    try {
      const balanceRes = await actions.budget.getMemberBalances({ tripId });
      const balances = Array.isArray(balanceRes) ? balanceRes : (balanceRes?.data || []);

      currentMembers = balances.map((b: any) => ({ id: b.user_id, name: b.user_name }));

      // Per-person breakdown (standard methods only)
      if (costSharing !== 'event_fee' && costSharing !== 'budget_pool' && balances.length > 1) {
        const heroEl = document.getElementById('hero-spent');
        const totalSpent = parseFloat(heroEl?.textContent?.replace(/[^0-9.]/g, '') || '0') || 0;
        if (totalSpent > 0) {
          const perPerson = totalSpent / balances.length;
          const badge = document.getElementById('per-person-badge');
          const amountEl = document.getElementById('per-person-amount');
          if (badge) badge.classList.remove('hidden');
          if (amountEl) amountEl.textContent = `₱${perPerson.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
        }
      }

      const select = document.getElementById('payer-select') as unknown as HTMLSelectElement;
      if (select) {
        select.innerHTML = '<option value="">Select who paid</option>' +
          currentMembers.map(m => `<option value="${m.id}">${m.name}</option>`).join('');
      }

      renderMemberCheckboxes();

      const section = document.getElementById('member-balances-body')?.closest('.mb-4') as HTMLElement | null;
      const body = document.getElementById('member-balances-body')!;
      if (!body) return;

      if (balances.length === 0) {
        body.innerHTML = `<div class="px-4 py-6 text-center text-sm text-gray-400">No members yet</div>`;
        return;
      }

      // For event_fee / budget_pool, hide this section entirely when no one owes anything
      const hasActivity = balances.some((b: any) =>
        parseFloat(b.net_balance) !== 0 || parseFloat(b.total_owed) !== 0 || parseFloat(b.total_paid) !== 0
      );
      if ((costSharing === 'event_fee' || costSharing === 'budget_pool') && !hasActivity) {
        if (section) section.classList.add('hidden');
        return;
      }
      if (section) section.classList.remove('hidden');

      body.innerHTML = balances.map((b: any, i: number) => {
        const balance = parseFloat(b.net_balance) || 0;
        const owes = parseFloat(b.total_owed) || 0;
        const paid = parseFloat(b.total_paid) || 0;
        const avatarColor = AVATAR_COLORS[i % AVATAR_COLORS.length];
        const balancePositive = balance >= 0;

        return `
          <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-50 last:border-b-0">
            ${avatarEl(b.avatar_url, b.user_name, avatarColor)}
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate">${b.user_name}</p>
              <p class="text-xs text-gray-400">Paid ₱${paid.toLocaleString()}</p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              ${owes > 0
                ? `<button class="owes-btn text-xs px-2 py-0.5 rounded-full bg-orange-50 border border-orange-200 text-orange-600 font-semibold hover:bg-orange-100 transition-colors"
                     data-user-id="${b.user_id}" data-user-name="${b.user_name}">
                     owes ₱${owes.toLocaleString()}
                   </button>`
                : `<span class="text-xs text-gray-300">settled</span>`
              }
              <span class="text-sm font-bold tabular-nums min-w-[4rem] text-right ${balancePositive ? 'text-green-600' : 'text-red-500'}">
                ${balancePositive ? '+' : ''}₱${Math.abs(balance).toLocaleString()}
              </span>
            </div>
          </div>
        `;
      }).join('');

      setupOwesHandlers(body);
    } catch (e) {
      console.error('Error loading balances:', e);
    }
  }

  // ── Member checkboxes ────────────────────────────────────────────────────────

  function renderMemberCheckboxes() {
    const container = document.getElementById('member-checkboxes');
    if (!container) return;

    const payerSelect = document.getElementById('payer-select') as HTMLSelectElement | null;
    const payerId = payerSelect?.value || '';

    if (currentMembers.length === 0) {
      container.innerHTML = `<p class="text-xs text-gray-400 text-center py-2">No members yet</p>`;
      return;
    }

    container.innerHTML = currentMembers.map((m, i) => {
      const avatarColor = AVATAR_COLORS[i % AVATAR_COLORS.length];
      const isPayer = m.id === payerId;
      return `
        <label class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-gray-100 cursor-pointer transition-colors">
          <input type="checkbox" class="member-checkbox rounded w-3.5 h-3.5 accent-blue-600"
            value="${m.id}" ${isPayer ? 'checked data-is-payer="true"' : 'checked'} />
          <div class="w-6 h-6 rounded-full ${avatarColor} flex items-center justify-center text-[10px] font-bold shrink-0">
            ${initials(m.name)}
          </div>
          <span class="text-xs font-medium text-gray-700 flex-1 truncate">${m.name}</span>
          ${isPayer ? `<span class="text-[10px] text-green-600 font-semibold bg-green-50 px-1.5 py-0.5 rounded-full">Paid</span>` : ''}
        </label>
      `;
    }).join('');

    container.querySelectorAll('.member-checkbox').forEach(cb => {
      cb.addEventListener('change', updatePerPersonCalc);
    });

    updatePerPersonCalc();
  }

  function updatePerPersonCalc() {
    const amountInput = document.querySelector('#expense-form [name="amount"]') as HTMLInputElement;
    const amount = parseFloat(amountInput?.value || '0') || 0;
    const checked = document.querySelectorAll('#member-checkboxes .member-checkbox:checked');
    const count = checked.length;
    const calcEl = document.getElementById('per-person-calc');
    if (!calcEl) return;

    if (amount > 0 && count > 0) {
      const perPerson = amount / count;
      calcEl.textContent = `₱${perPerson.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} each · ${count} covered`;
    } else if (count > 0) {
      calcEl.textContent = `${count} covered`;
    } else {
      calcEl.textContent = '';
    }
  }

  // ── Shared handlers ──────────────────────────────────────────────────────────

  function setupPaymentHandlers(body: HTMLElement, reload: () => Promise<void>) {
    // Full payment — inline two-step confirm
    body.querySelectorAll('.pay-full-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const contributionId = el.dataset.contributionId;
        const userName = el.dataset.userName;
        const area = el.closest('.payment-action-area') as HTMLElement;
        if (!contributionId || !area) return;

        const original = area.innerHTML;
        area.innerHTML = `
          <span class="text-xs text-gray-600">Paid in full?</span>
          <button class="confirm-full-yes text-xs px-2 py-1 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-700 transition-colors">Yes</button>
          <button class="confirm-full-no text-xs text-gray-400 hover:text-gray-600 font-semibold transition-colors">No</button>
        `;
        area.querySelector('.confirm-full-no')?.addEventListener('click', () => { area.innerHTML = original; setupPaymentHandlers(body, reload); });
        area.querySelector('.confirm-full-yes')?.addEventListener('click', async () => {
          const res = await actions.budget.recordPoolPayment({ contributionId, tripId: tripId!, paymentAmount: 0, fullPayment: true });
          if (!(res as any).error) {
            showToast({ message: `Full payment recorded for ${userName}`, type: 'success' });
            await reload();
          }
        });
      });
    });

    // Partial payment — inline amount input
    body.querySelectorAll('.pay-partial-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const el = e.currentTarget as HTMLElement;
        const contributionId = el.dataset.contributionId;
        const userName = el.dataset.userName;
        const remaining = parseFloat(el.dataset.remaining || '0');
        const area = el.closest('.payment-action-area') as HTMLElement;
        if (!contributionId || !area) return;

        const original = area.innerHTML;
        area.innerHTML = `
          <input type="number" class="partial-amount-input w-20 px-2 py-1 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 outline-none"
            placeholder="₱ amount" min="1" max="${remaining}" step="1" />
          <button class="confirm-partial-yes text-xs px-2 py-1 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors">OK</button>
          <button class="confirm-partial-no text-xs text-gray-400 hover:text-gray-600 font-semibold transition-colors">✕</button>
        `;
        const input = area.querySelector('.partial-amount-input') as HTMLInputElement;
        input?.focus();
        area.querySelector('.confirm-partial-no')?.addEventListener('click', () => { area.innerHTML = original; setupPaymentHandlers(body, reload); });
        area.querySelector('.confirm-partial-yes')?.addEventListener('click', async () => {
          const amt = parseFloat(input?.value || '0');
          if (!amt || amt <= 0) { input?.focus(); return; }
          const res = await actions.budget.recordPoolPayment({ contributionId, tripId: tripId!, paymentAmount: amt, fullPayment: false });
          if (!(res as any).error) {
            showToast({ message: `₱${amt.toLocaleString()} recorded for ${userName}`, type: 'success' });
            await reload();
          }
        });
      });
    });

    // Mark Refunded — inline two-step confirm
    body.querySelectorAll('.mark-refunded-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const contributionId = el.dataset.contributionId;
        const userName = el.dataset.userName;
        const amount = parseFloat(el.dataset.amount || '0');
        const area = el.closest('.payment-action-area') as HTMLElement;
        if (!contributionId || !area) return;

        const original = area.innerHTML;
        area.innerHTML = `
          <span class="text-xs text-gray-500">Refunded ₱${amount.toLocaleString()} to ${userName}?</span>
          <button class="confirm-refund-yes text-xs px-2 py-1 rounded-lg bg-gray-600 text-white font-semibold hover:bg-gray-700 transition-colors">Yes</button>
          <button class="confirm-refund-no text-xs text-gray-400 hover:text-gray-600 font-semibold transition-colors">✕</button>
        `;
        area.querySelector('.confirm-refund-no')?.addEventListener('click', () => { area.innerHTML = original; setupPaymentHandlers(body, reload); });
        area.querySelector('.confirm-refund-yes')?.addEventListener('click', async () => {
          const res = await actions.budget.markContributionRefunded({ contributionId, tripId: tripId! });
          if (!(res as any).error) {
            showToast({ message: `Marked ₱${amount.toLocaleString()} as refunded to ${userName}`, type: 'success' });
            await reload();
          }
        });
      });
    });
  }

  function setupOwesHandlers(body: HTMLElement) {
    body.querySelectorAll('.owes-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLElement;
        const uid = target.dataset.userId;
        const userName = target.dataset.userName;
        if (!uid || !tripId) return;

        const modalTitle = document.getElementById('owes-modal-title');
        if (modalTitle) modalTitle.textContent = `${userName} owes`;

        const modalContent = document.getElementById('owes-modal-content')!;
        modalContent.innerHTML = `<p class="text-sm text-gray-400 text-center py-4">Loading...</p>`;
        (document.getElementById('owes-modal') as HTMLDialogElement)?.showModal();

        try {
          const result = await actions.budget.getMemberOwes({ tripId, userId: uid });
          const owes = Array.isArray(result) ? result : (result?.data || []);

          if (owes.length === 0) {
            modalContent.innerHTML = `<p class="text-sm text-gray-400 text-center py-4">No outstanding balances</p>`;
          } else {
            modalContent.innerHTML = `
              <div class="space-y-2">
                ${owes.map((o: any) => `
                  <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl owes-item" data-split-id="${o.split_id}">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-900 truncate">${o.expense_description || '—'}</p>
                      <p class="text-xs text-gray-400">${new Date(o.expense_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} · to ${o.payer_name}</p>
                    </div>
                    <div class="text-right shrink-0">
                      <p class="text-sm font-bold text-gray-900">₱${parseFloat(o.share_amount).toLocaleString()}</p>
                      <button class="settle-expense-btn text-xs font-semibold text-blue-600 hover:text-blue-700 transition-colors mt-0.5"
                        data-split-id="${o.split_id}"
                        data-expense-desc="${o.expense_description}"
                        data-amount="${o.share_amount}"
                        data-payer="${o.payer_name}">
                        Settle →
                      </button>
                    </div>
                  </div>
                `).join('')}
              </div>
            `;

            modalContent.querySelectorAll('.settle-expense-btn').forEach(settleBtn => {
              settleBtn.addEventListener('click', async (e) => {
                const btn = e.currentTarget as HTMLElement;
                const splitId = btn.dataset.splitId;
                if (!splitId) return;

                const item = btn.closest('.owes-item') as HTMLElement;
                const amount = btn.dataset.amount || '0';
                const originalContent = item.innerHTML;

                item.innerHTML = `
                  <div class="flex items-center justify-between w-full gap-3">
                    <p class="text-sm text-gray-600">Settle ₱${parseFloat(amount).toLocaleString()}?</p>
                    <div class="flex gap-2 shrink-0">
                      <button class="confirm-settle-no px-3 py-1.5 text-xs font-semibold text-gray-600 hover:bg-gray-200 rounded-lg transition-colors">Cancel</button>
                      <button class="confirm-settle-yes px-3 py-1.5 text-xs font-semibold bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors">Confirm</button>
                    </div>
                  </div>
                `;

                item.querySelector('.confirm-settle-no')?.addEventListener('click', () => {
                  item.innerHTML = originalContent;
                  item.querySelector('.settle-expense-btn')?.addEventListener('click', () => btn.click());
                });

                item.querySelector('.confirm-settle-yes')?.addEventListener('click', async () => {
                  const result = await actions.budget.settleExpenseSplit({ splitId, tripId: tripId! });
                  if (!(result as any).error) {
                    showToast({ message: 'Settled!', type: 'success' });
                    item.remove();
                    await loadMemberBalances();
                    const remaining = modalContent?.querySelectorAll('.owes-item');
                    if (!remaining || remaining.length === 0) {
                      modalContent.innerHTML = `<p class="text-sm text-gray-400 text-center py-4">No outstanding balances</p>`;
                    }
                  }
                });
              });
            });
          }
        } catch (err) {
          console.error('Error loading owes:', err);
          modalContent.innerHTML = `<p class="text-sm text-red-500 text-center py-4">Error loading details</p>`;
        }
      });
    });
  }

  // ── Event listeners ──────────────────────────────────────────────────────────

  document.getElementById('add-expense-btn')?.addEventListener('click', () => {
    (document.getElementById('expense-modal') as HTMLDialogElement)?.showModal();
  });

  document.getElementById('budget-settings-btn')?.addEventListener('click', () => {
    // Reset method select and warnings to current state before opening
    const select = document.getElementById('settings-method-select') as HTMLSelectElement | null; 
    if (select) select.value = costSharing;
    const warningBox = document.getElementById('method-change-warnings');
    if (warningBox) { warningBox.innerHTML = ''; warningBox.classList.add('hidden'); }
    (document.getElementById('budget-settings-modal') as HTMLDialogElement)?.showModal();
  });

  // Helpers
  const isPoolMethod = (m: string) => m === 'event_fee' || m === 'budget_pool';
  const fmt = (n: number) => n.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  // Settings method change → toggle fields + fetch reconciliation warnings
  document.getElementById('settings-method-select')?.addEventListener('change', async (e) => {
    const method = (e.target as HTMLSelectElement).value;
    const needsPerPerson = isPoolMethod(method);
    document.getElementById('per-person-group')?.classList.toggle('hidden', !needsPerPerson);
    document.getElementById('budget-estimate-group')?.classList.toggle('hidden', needsPerPerson);

    const label = document.getElementById('per-person-label');
    const hint  = document.getElementById('per-person-hint');
    if (label) label.textContent = method === 'event_fee' ? 'Fee per Person (₱)' : 'Target per Person (₱)';
    if (hint)  hint.textContent  = method === 'event_fee'
      ? 'Auto-charged when a member joins.'
      : 'How much each member contributes to the pool.';

    const warningBox = document.getElementById('method-change-warnings');
    if (!warningBox) return;

    if (method === costSharing) {
      // No method change — no warnings needed
      warningBox.innerHTML = '';
      warningBox.classList.add('hidden');
      return;
    }

    // Fetch unsettled obligations
    warningBox.innerHTML = `<p class="text-xs text-gray-400 animate-pulse">Checking existing obligations…</p>`;
    warningBox.classList.remove('hidden');

    const res = await actions.budget.getUnsettledSummary({ tripId: tripId! });
    if (res.error || !res.data) {
      warningBox.innerHTML = '';
      warningBox.classList.add('hidden');
      return;
    }

    const s = res.data;
    const hasSplits    = s.splits.count > 0;
    const hasPool      = s.pool.count > 0;
    const hasPaidPool  = s.pool.paid_total > 0;
    const hasRefundable = (s.refundable?.count ?? 0) > 0;
    const fromPool     = isPoolMethod(costSharing);
    const toPool       = isPoolMethod(method);

    let html = '';

    // ── Warning A: unsettled expense splits ─────────────────────────────
    if (hasSplits) {
      const memberList = s.splits.members.map(m =>
        `<span class="inline-block bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded">${m.display_name} ₱${fmt(m.amount_owed)}</span>`
      ).join(' ');
      html += `
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 space-y-2">
          <p class="text-xs font-semibold text-amber-800">
            ⚠️ ${s.splits.count} member${s.splits.count > 1 ? 's have' : ' has'} ₱${fmt(s.splits.total)} in unsettled splits
          </p>
          <div class="flex flex-wrap gap-1">${memberList}</div>
          <p class="text-xs text-amber-700">
            These were calculated under <strong>${costSharing.replace(/_/g, ' ')}</strong> and will carry over unless written off.
          </p>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="checkbox" id="write-off-splits" name="writeOffSplits" class="mt-0.5 accent-amber-600" />
            <span class="text-xs text-amber-800 font-medium">
              Write off all unsettled splits — mark everyone as settled (no one owes anything from past expenses)
            </span>
          </label>
        </div>`;
    }

    // ── Warning B: pool contributions, switching AWAY from pool ─────────
    if ((hasPool || hasPaidPool) && fromPool && !toPool) {
      const memberList = s.pool.members.map(m =>
        `<span class="inline-block bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded">${m.display_name} ₱${fmt(m.amount_remaining)} left</span>`
      ).join(' ');
      html += `
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 space-y-2">
          <p class="text-xs font-semibold text-blue-800">
            💰 ${s.pool.count} member${s.pool.count > 1 ? 's have' : ' has'} unpaid contributions
            (₱${fmt(s.pool.pending_total)} remaining · ₱${fmt(s.pool.paid_total)} already collected)
          </p>
          <div class="flex flex-wrap gap-1">${memberList}</div>
          <p class="text-xs text-blue-700 font-medium mt-1">What to do with pending contributions?</p>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="radio" name="poolAction" value="keep" checked class="mt-0.5 accent-blue-600" />
            <span class="text-xs text-blue-800">Keep pending — members still owe their contribution</span>
          </label>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="radio" name="poolAction" value="cancel" class="mt-0.5 accent-blue-600" />
            <span class="text-xs text-blue-800">
              Cancel unpaid — remove fully-pending; close partial payments at amount already paid
              <span class="text-blue-500">(paid credit preserved, remaining forgiven)</span>
            </span>
          </label>
        </div>`;
    }

    // ── Warning C: pool contributions, switching BETWEEN pool methods ───
    if ((hasPool || hasPaidPool) && fromPool && toPool) {
      const memberList = s.pool.members.map(m =>
        `<span class="inline-block bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded">${m.display_name} paid ₱${fmt(m.amount_paid)}</span>`
      ).join(' ');
      html += `
        <div class="bg-purple-50 border border-purple-200 rounded-xl p-3 space-y-2">
          <p class="text-xs font-semibold text-purple-800">
            🔄 ${s.pool.members.length + (hasPaidPool ? 1 : 0)} member(s) have existing contributions
            (₱${fmt(s.pool.paid_total)} collected so far)
          </p>
          <div class="flex flex-wrap gap-1">${memberList}</div>
          <p class="text-xs text-purple-700 font-medium mt-1">How to handle existing contributions?</p>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="radio" name="poolAction" value="transfer" checked class="mt-0.5 accent-purple-600" />
            <span class="text-xs text-purple-800">
              Transfer to new method — adjust target to the new per-person amount.
              Members who overpaid will be marked as paid (refund offline).
            </span>
          </label>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="radio" name="poolAction" value="cancel" class="mt-0.5 accent-purple-600" />
            <span class="text-xs text-purple-800">
              Cancel all unpaid — remove pending; close partial at amount paid
            </span>
          </label>
        </div>`;
    }

    // ── Warning D: fully-paid contributions that need refunding (away from pool)
    if (hasRefundable && fromPool && !toPool) {
      const memberList = (s.refundable?.members ?? []).map(m =>
        `<span class="inline-block bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded">${m.display_name} ₱${fmt(m.amount_paid)}</span>`
      ).join(' ');
      html += `
        <div class="bg-red-50 border border-red-200 rounded-xl p-3 space-y-2">
          <p class="text-xs font-semibold text-red-800">
            💸 ${s.refundable!.count} member${s.refundable!.count > 1 ? 's have' : ' has'} already paid ₱${fmt(s.refundable!.total)} into the pool
          </p>
          <div class="flex flex-wrap gap-1">${memberList}</div>
          <p class="text-xs text-red-700">
            These members need to be reimbursed manually (cash, bank transfer, etc.).<br/>
            Use <strong>Mark Refunded</strong> on each contribution after you've paid them back.
          </p>
        </div>`;
    }

    if (!html) {
      // Nothing outstanding — clean transition
      html = `<p class="text-xs text-green-600 bg-green-50 border border-green-200 rounded-xl px-3 py-2">
        ✅ No outstanding obligations. This is a clean transition.
      </p>`;
    }

    warningBox.innerHTML = html;
    warningBox.classList.remove('hidden');
  });

  // Per-person input: show a live hint when owner adjusts target on same pool method
  // (e.g. raising target to cover an overdrawn pool)
  {
    const poolPerPersonInput = document.querySelector('#budget-settings-form [name="poolPerPerson"]') as HTMLInputElement | null;
    const perPersonHint      = document.getElementById('per-person-hint');

    poolPerPersonInput?.addEventListener('input', () => {
      const methodSelect = document.getElementById('settings-method-select') as HTMLSelectElement | null;
      const currentMethod = methodSelect?.value || costSharing;
      if (!isPoolMethod(currentMethod) || currentMethod !== costSharing) return;

      const newTarget = parseFloat(poolPerPersonInput.value) || 0;
      const hint = perPersonHint;
      if (!hint || newTarget <= 0) {
        if (hint) hint.textContent = 'How much each member contributes to the pool.';
        return;
      }

      // Show a preview: "Saving will recalculate all contributions to ₱X/person."
      hint.textContent = `Saving will recalculate all contributions to ₱${newTarget.toLocaleString()}/person. Members who paid less will owe the difference.`;
      hint.className = 'text-xs mt-1 text-blue-600';
    });
  }

  // Show payment source toggle for budget_pool
  if (costSharing === 'budget_pool') {
    document.getElementById('payment-source-group')?.classList.remove('hidden');
  }

  function updatePaymentSourceStyles() {
    const isPool = (document.querySelector('[name="paymentSource"]:checked') as HTMLInputElement)?.value === 'pool';
    const personalLabel = document.getElementById('ps-personal-label');
    const poolLabel = document.getElementById('ps-pool-label');
    if (personalLabel) {
      personalLabel.className = personalLabel.className.replace(/border-(blue-500|gray-200)/g, isPool ? 'border-gray-200' : 'border-blue-500');
      personalLabel.classList.toggle('bg-blue-50', !isPool);
    }
    if (poolLabel) {
      poolLabel.className = poolLabel.className.replace(/border-(blue-500|gray-200)/g, isPool ? 'border-blue-500' : 'border-gray-200');
      poolLabel.classList.toggle('bg-blue-50', isPool);
    }
    // Hide payer select and covered members when paying from pool
    const payerGroup = document.getElementById('payer-select-group');
    const payerSelect = document.getElementById('payer-select') as HTMLSelectElement | null;
    if (payerGroup) payerGroup.classList.toggle('hidden', isPool);
    if (payerSelect) payerSelect.required = !isPool;
    document.getElementById('covered-members-section')?.classList.toggle('hidden', isPool);
  }

  document.querySelectorAll('[name="paymentSource"]').forEach(radio => {
    radio.addEventListener('change', updatePaymentSourceStyles);
  });

  // Payer change → refresh member checkboxes (update "Paid" badge)
  document.getElementById('payer-select')?.addEventListener('change', () => {
    renderMemberCheckboxes();
  });

  // Select all / unselect all members
  document.getElementById('select-all-members')?.addEventListener('click', () => {
    document.querySelectorAll('#member-checkboxes .member-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = true;
    });
    updatePerPersonCalc();
  });

  document.getElementById('unselect-all-members')?.addEventListener('click', () => {
    const payerSelect = document.getElementById('payer-select') as HTMLSelectElement | null;
    const payerId = payerSelect?.value || '';
    document.querySelectorAll('#member-checkboxes .member-checkbox').forEach(cb => {
      const input = cb as HTMLInputElement;
      // Keep payer checked (they're always included)
      if (input.value !== payerId) input.checked = false;
    });
    updatePerPersonCalc();
  });

  // Amount change → update per-person calc
  document.querySelector('#expense-form [name="amount"]')?.addEventListener('input', updatePerPersonCalc);

  // Reset form state when modal closes
  document.getElementById('expense-modal')?.addEventListener('close', () => {
    // Reset payment source to personal
    const personalRadio = document.querySelector('[name="paymentSource"][value="personal"]') as HTMLInputElement;
    if (personalRadio) { personalRadio.checked = true; updatePaymentSourceStyles(); }
    renderMemberCheckboxes();
  });

  // Expense form submit
  const expenseForm = document.getElementById('expense-form') as HTMLFormElement;
  expenseForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(expenseForm);
    const submitBtn = expenseForm.querySelector('[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';

    const paymentSource = (formData.get('paymentSource') as string) || 'personal';
    const fromPool = paymentSource === 'pool';

    const checkedBoxes = document.querySelectorAll('#member-checkboxes .member-checkbox:checked');
    const recipientIds = Array.from(checkedBoxes).map(cb => (cb as HTMLInputElement).value);

    const currentUserId = container?.dataset.userId || '';
    const payerId = fromPool ? currentUserId : (formData.get('payerId') as string);

    try {
      const result = await actions.budget.addExpense({
        tripId: tripId!,
        payerId,
        amount: parseFloat(formData.get('amount') as string),
        description: formData.get('description') as string,
        category: formData.get('category') as any,
        date: formData.get('date') as string,
        isShared: fromPool ? false : recipientIds.length > 1,
        recipientIds: fromPool ? undefined : (recipientIds.length > 0 ? recipientIds : undefined),
        paidFromPool: fromPool,
      });

      if (!(result as any).error) {
        showToast({ message: 'Expense added!', type: 'success' });
        (document.getElementById('expense-modal') as HTMLDialogElement)?.close();
        expenseForm.reset();
        renderMemberCheckboxes();
        loadData();
      }
    } catch (err) {
      console.error('Error adding expense:', err);
      showToast({ message: 'Error adding expense', type: 'error' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Add Expense';
    }
  });

  // Settings form submit
  // Uses changeCostSharing (which handles reconciliation atomically) for ALL saves.
  const settingsForm = document.getElementById('budget-settings-form') as HTMLFormElement;
  settingsForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData   = new FormData(settingsForm);
    const method     = formData.get('costSharingMethod') as string;
    const needsPool  = isPoolMethod(method);
    const submitBtn  = settingsForm.querySelector('[type="submit"]') as HTMLButtonElement;

    // Read reconciliation options (only present when warnings were shown)
    const writeOffSplits = (document.getElementById('write-off-splits') as HTMLInputElement)?.checked ?? false;

    // When staying on a pool method and just adjusting the per-person target,
    // auto-transfer so all existing contributions are recalculated to the new amount.
    // This lets the owner top-up an overdrawn pool by raising the target.
    const poolAction: 'keep' | 'cancel' | 'transfer' = (needsPool && method === costSharing)
      ? 'transfer'
      : ((formData.get('poolAction') as 'keep' | 'cancel' | 'transfer') ?? 'keep');

    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    try {
      const result = await actions.budget.changeCostSharing({
        tripId:            tripId!,
        newMethod:         method as any,
        budgetEstimate:    !needsPool && formData.get('budgetEstimate')
                             ? parseFloat(formData.get('budgetEstimate') as string)
                             : null,
        poolPerPerson:     needsPool && formData.get('poolPerPerson')
                             ? parseFloat(formData.get('poolPerPerson') as string)
                             : null,
        allowMembersToLog: true,
        writeOffSplits,
        poolAction,
      });

      if (!result.error) {
        const d = result.data;
        const parts: string[] = ['Settings saved!'];
        if (d?.splits_written_off)  parts.push(`${d.splits_written_off} split(s) written off.`);
        if (d?.pool_cancelled)      parts.push(`${d.pool_cancelled} contribution(s) cancelled.`);
        if (d?.pool_transferred)    parts.push(`${d.pool_transferred} contribution(s) recalculated to new target.`);
        showToast({ message: parts.join(' '), type: 'success' });
        (document.getElementById('budget-settings-modal') as HTMLDialogElement)?.close();
        window.location.reload();
      }
    } catch (err) {
      console.error('Error saving settings:', err);
      showToast({ message: 'Error saving settings', type: 'error' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save Settings';
    }
  });

  loadData();

  // ── Transaction Log ──────────────────────────────────────────────────────────

  const TX_TYPE_CONFIG: Record<string, { icon: string; label: string; badgeClass: string }> = {
    contribution: { icon: '💰', label: 'Contribution',  badgeClass: 'bg-green-50 text-green-700 border border-green-100' },
    fee_payment:  { icon: '🎟️', label: 'Fee Payment',   badgeClass: 'bg-green-50 text-green-700 border border-green-100' },
    refund:       { icon: '↩',  label: 'Refund',        badgeClass: 'bg-rose-50 text-rose-600 border border-rose-100' },
    pool_expense: { icon: '💸', label: 'Pool Expense',  badgeClass: 'bg-orange-50 text-orange-600 border border-orange-100' },
    expense:      { icon: '🧾', label: 'Expense',       badgeClass: 'bg-gray-100 text-gray-600 border border-gray-200' },
    settlement:   { icon: '✅', label: 'Settlement',    badgeClass: 'bg-teal-50 text-teal-700 border border-teal-100' },
  };

  function relativeTime(iso: string): string {
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1)   return 'just now';
    if (mins < 60)  return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24)   return `${hrs}h ago`;
    const days = Math.floor(hrs / 24);
    if (days < 7)   return `${days}d ago`;
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function renderTxRow(tx: any, i: number): string {
    const cfg = TX_TYPE_CONFIG[tx.event_type] ?? TX_TYPE_CONFIG.expense;
    const color = AVATAR_COLORS[i % AVATAR_COLORS.length];
    const name = tx.actor_name || '—';
    const amtStr = `₱${parseFloat(tx.amount).toLocaleString()}`;
    const amtColor = tx.direction === 'in'
      ? 'text-green-600'
      : tx.direction === 'out'
        ? 'text-rose-600'
        : 'text-gray-700';
    const amtPrefix = tx.direction === 'in' ? '+' : tx.direction === 'out' ? '−' : '';
    const balanceHtml = tx.running_balance !== null && tx.running_balance !== undefined
      ? `<span class="text-xs text-gray-400 tabular-nums">bal ₱${parseFloat(tx.running_balance).toLocaleString()}</span>`
      : '';

    return `
      <div class="flex items-start gap-3 px-4 py-3 border-b border-gray-50 last:border-b-0">
        ${avatarEl(tx.actor_avatar, name, color, 'w-8 h-8')}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1.5 flex-wrap">
            <span class="text-xs font-semibold text-gray-800 truncate">${name}</span>
            <span class="text-xs px-1.5 py-0.5 rounded-full font-medium ${cfg.badgeClass}">${cfg.icon} ${cfg.label}</span>
          </div>
          <p class="text-xs text-gray-700 truncate mt-0.5">${tx.label || '—'}</p>
          <p class="text-xs text-gray-400 truncate">${tx.sub_label || ''}</p>
        </div>
        <div class="text-right shrink-0">
          <p class="text-sm font-bold tabular-nums ${amtColor}">${amtPrefix}${amtStr}</p>
          <p class="text-xs text-gray-400">${relativeTime(tx.event_at)}</p>
          ${balanceHtml}
        </div>
      </div>`;
  }

  let txlogLoaded = false;

  async function loadTransactionLog() {
    if (!tripId) return;
    const body = document.getElementById('txlog-body')!;
    if (!body) return;
    try {
      const result = await actions.budget.getTransactionLog({ tripId });
      const entries: any[] = Array.isArray(result) ? result : ((result as any)?.data ?? []);

      const badge = document.getElementById('txlog-badge');
      if (badge) {
        badge.textContent = String(entries.length);
        badge.classList.toggle('hidden', entries.length === 0);
      }

      if (entries.length === 0) {
        body.innerHTML = `<div class="px-4 py-6 text-center text-sm text-gray-400">No transactions yet</div>`;
        return;
      }

      body.innerHTML = entries.map((tx, i) => renderTxRow(tx, i)).join('');
    } catch (e) {
      console.error('Error loading transaction log:', e);
      body.innerHTML = `<div class="px-4 py-6 text-center text-sm text-gray-400">Could not load log</div>`;
    }
  }

  document.getElementById('txlog-toggle')?.addEventListener('click', async () => {
    const body = document.getElementById('txlog-body')!;
    const chevron = document.getElementById('txlog-chevron');
    const isOpen = !body.classList.contains('hidden');
    body.classList.toggle('hidden', isOpen);
    chevron?.style.setProperty('transform', isOpen ? '' : 'rotate(180deg)');
    if (!isOpen && !txlogLoaded) {
      txlogLoaded = true;
      await loadTransactionLog();
    }
  });
</script>
