---
import { PUBLIC_R2_URL } from "astro:env/client";
import UploadImages from "./UploadImages.astro";

interface TripImage {
  key_name: string;
  type: 'hero' | 'gallery';
  image_url: string;
  alt?: string;
  location?: string;
  description?: string;
}

interface Props {
  trip_images?: TripImage[];
  userRole?: string;
}

const { trip_images = [], userRole }: Props = Astro.props;

const isOwner = userRole === 'owner';
const heroImages = trip_images?.filter((img) => img.type === "hero");
const totalSlides = isOwner ? heroImages?.length + 1 : heroImages?.length;

const getPrevSlide = (current: number) => current - 1 <= 0 ? totalSlides : current - 1;
const getNextSlide = (current: number) => current + 1 > totalSlides ? 1 : current + 1;
---

<!-- Carousel wrapper -->
<div
  role="region"
  aria-label="Image carousel"
  aria-live="polite"
  class="w-full"
>
  <!-- Slides track -->
  <div class="carousel w-full overflow-hidden bg-gray-900">

    <!-- IMAGE SLIDES -->
    {heroImages?.map((image, index) => {
      const slideNum = index + 1;
      const slideId = `slide${slideNum}`;
      const prevId = `slide${getPrevSlide(slideNum)}`;
      const nextId = `slide${getNextSlide(slideNum)}`;

      return (
        <div
          id={slideId}
          class="carousel-item relative w-full flex items-center justify-center overflow-hidden aspect-[4/3] md:aspect-video"
        >
          <!-- Blurred color backdrop — fills dead space with the photo's own colours -->
          <img
            src={`${PUBLIC_R2_URL}${image?.image_url}`}
            alt=""
            aria-hidden="true"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover scale-110 blur-xl brightness-75 saturate-150 opacity-80 pointer-events-none select-none"
          />

          <!-- Actual photo — always fully visible, never cropped -->
          <img
            src={`${PUBLIC_R2_URL}${image?.image_url}`}
            alt={image.alt || "Trip photo"}
            loading="lazy"
            class="relative z-10 max-w-full max-h-full object-contain"
          />

          <!-- Caption overlay (only when caption data exists) -->
          {(image?.location || image?.description) && (
            <div class="absolute bottom-0 left-0 right-0 z-20 bg-gradient-to-t from-black/70 via-black/30 to-transparent px-5 pb-5 pt-10">
              {image?.location && (
                <p class="text-white font-bold text-base md:text-lg leading-tight">{image.location}</p>
              )}
              {image?.description && (
                <p class="text-white/80 text-xs md:text-sm mt-0.5">{image.description}</p>
              )}
            </div>
          )}

          <!-- Slide counter badge (top-right) -->
          {totalSlides > 1 && (
            <span class="absolute top-3 right-3 z-20 text-xs font-semibold text-white bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-full">
              {slideNum} / {totalSlides}
            </span>
          )}

          <!-- Prev / Next arrows -->
          {totalSlides > 1 && (
            <div class="absolute inset-x-3 top-1/2 -translate-y-1/2 z-20 flex justify-between pointer-events-none">
              <a
                href={`#${prevId}`}
                class="pointer-events-auto w-9 h-9 md:w-11 md:h-11 flex items-center justify-center rounded-full bg-black/30 backdrop-blur-sm hover:bg-black/50 text-white text-sm font-bold transition"
                aria-label={`Previous image`}
              >❮</a>
              <a
                href={`#${nextId}`}
                class="pointer-events-auto w-9 h-9 md:w-11 md:h-11 flex items-center justify-center rounded-full bg-black/30 backdrop-blur-sm hover:bg-black/50 text-white text-sm font-bold transition"
                aria-label={`Next image`}
              >❯</a>
            </div>
          )}
        </div>
      );
    })}

    <!-- UPLOAD SLIDE (owner only) -->
    {isOwner && (() => {
      const slideNum = heroImages?.length + 1;
      const slideId = `slide${slideNum}`;
      const prevId = `slide${getPrevSlide(slideNum)}`;
      const nextId = `slide${getNextSlide(slideNum)}`;

      return (
        <div
          id={slideId}
          class="carousel-item relative w-full flex items-center justify-center bg-gradient-to-br from-slate-900 to-blue-950 aspect-[4/3] md:aspect-video"
        >
          <!-- Upload card -->
          <div class="border-2 border-dashed border-blue-500/40 bg-slate-800/80 backdrop-blur-sm rounded-2xl p-8 md:p-10 max-w-sm mx-4 shadow-2xl">
            <div class="text-center space-y-4">
              <div class="w-14 h-14 mx-auto bg-blue-500/20 rounded-full flex items-center justify-center border border-blue-500/30">
                <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
              </div>
              <div>
                <h2 class="text-lg font-bold text-white">Add Hero Photo</h2>
                <p class="text-blue-200/60 text-sm mt-1">Upload photos of your adventure</p>
              </div>
              <UploadImages />
            </div>
          </div>

          <!-- Slide counter badge -->
          {totalSlides > 1 && (
            <span class="absolute top-3 right-3 z-20 text-xs font-semibold text-white bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-full">
              {slideNum} / {totalSlides}
            </span>
          )}

          <!-- Prev / Next arrows -->
          {totalSlides > 1 && (
            <div class="absolute inset-x-3 top-1/2 -translate-y-1/2 z-20 flex justify-between pointer-events-none">
              <a
                href={`#${prevId}`}
                class="pointer-events-auto w-9 h-9 md:w-11 md:h-11 flex items-center justify-center rounded-full bg-slate-700/60 backdrop-blur-sm hover:bg-slate-600/70 text-blue-300 text-sm font-bold transition"
                aria-label="Previous image"
              >❮</a>
              <a
                href={`#${nextId}`}
                class="pointer-events-auto w-9 h-9 md:w-11 md:h-11 flex items-center justify-center rounded-full bg-slate-700/60 backdrop-blur-sm hover:bg-slate-600/70 text-blue-300 text-sm font-bold transition"
                aria-label="Next image"
              >❯</a>
            </div>
          )}
        </div>
      );
    })()}
  </div>

  <!-- Dot indicators — below the image, not overlapping it -->
  {totalSlides > 1 && (
    <div
      class="flex justify-center gap-2 py-2.5 bg-white"
      role="tablist"
      aria-label="Slide navigation"
    >
      {Array.from({ length: totalSlides }).map((_, i) => {
        const slideNum = i + 1;
        return (
          <a
            href={`#slide${slideNum}`}
            role="tab"
            aria-label={`Go to slide ${slideNum}`}
            class="indicator-dot w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 transition-all"
            data-slide={slideNum}
          />
        );
      })}
    </div>
  )}
</div>

<script define:vars={{ totalSlides }}>
  function initCarousel() {
    const carousel = document.querySelector('.carousel');
    const indicators = document.querySelectorAll('.indicator-dot');
    let currentSlide = 1;

    if (!carousel) return;

    const updateCurrentSlide = () => {
      const match = window.location.hash.match(/slide(\d+)/);
      currentSlide = match ? parseInt(match[1]) : 1;
      updateIndicators();
    };

    const updateIndicators = () => {
      indicators.forEach((dot) => {
        const n = parseInt(dot.getAttribute('data-slide') || '0');
        if (n === currentSlide) {
          dot.classList.add('bg-blue-500', 'scale-125');
          dot.classList.remove('bg-gray-300');
        } else {
          dot.classList.remove('bg-blue-500', 'scale-125');
          dot.classList.add('bg-gray-300');
        }
      });
    };

    if (!window.location.hash) window.location.hash = 'slide1';
    updateCurrentSlide();

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        currentSlide = currentSlide - 1 <= 0 ? totalSlides : currentSlide - 1;
        window.location.hash = `slide${currentSlide}`;
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        currentSlide = currentSlide + 1 > totalSlides ? 1 : currentSlide + 1;
        window.location.hash = `slide${currentSlide}`;
      }
    });

    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) < 50) return;
      if (diff > 0) {
        currentSlide = currentSlide + 1 > totalSlides ? 1 : currentSlide + 1;
      } else {
        currentSlide = currentSlide - 1 <= 0 ? totalSlides : currentSlide - 1;
      }
      window.location.hash = `slide${currentSlide}`;
    }, { passive: true });

    window.addEventListener('hashchange', updateCurrentSlide);
    indicators.forEach((dot) => dot.addEventListener('click', () => setTimeout(updateCurrentSlide, 50)));
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
  document.addEventListener('astro:page-load', initCarousel);
</script>

<style>
  .carousel { scroll-behavior: smooth; }
  .indicator-dot { transition: all 0.25s ease; }
</style>
