---
import ActivityList from './ActivityList.astro';
import type { ItineraryStop } from '@/types/itinerary';
import { getStopColors } from '@/utility/stopColors';

interface Props {
  completeStop: any;
  isOwner: boolean;
}

const { completeStop, isOwner } = Astro.props;
const stopType = completeStop.stop_type ?? completeStop.location_type;
const locationName = completeStop.location_name ?? completeStop.location?.name;
const colors = getStopColors(stopType);

const formatTime = (iso: string | null | undefined): string => {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true, timeZone: 'Asia/Manila' });
};

const addMinutes = (iso: string, minutes: number): string => {
  const d = new Date(new Date(iso).getTime() + minutes * 60_000);
  return d.toISOString();
};

const waitingTime: number = completeStop.waiting_time ?? 0;

// Resolve start and end, filling gaps with waiting_time
let resolvedStart = completeStop.scheduled_start || null;
let resolvedEnd   = completeStop.scheduled_end   || null;

if (resolvedStart && !resolvedEnd && waitingTime > 0) {
  resolvedEnd = addMinutes(resolvedStart, waitingTime);
} else if (!resolvedStart && resolvedEnd && waitingTime > 0) {
  resolvedStart = addMinutes(resolvedEnd, -waitingTime);
}

const startLabel = formatTime(resolvedStart);
const endLabel   = formatTime(resolvedEnd);
const stopTime   = startLabel && endLabel && startLabel !== endLabel
  ? `${startLabel} – ${endLabel}`
  : startLabel || endLabel;

// Multi-day detection (compare calendar dates in Asia/Manila)
const toManilaDate = (iso: string | null): string => {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-CA', { timeZone: 'Asia/Manila' }); // YYYY-MM-DD
};
const startCalDate = toManilaDate(resolvedStart);
const endCalDate   = toManilaDate(resolvedEnd);
const isMultiDay   = !!(startCalDate && endCalDate && startCalDate !== endCalDate);
const endDayLabel  = isMultiDay
  ? new Date(resolvedEnd!).toLocaleDateString('en-US', {
      weekday: 'short', month: 'short', day: 'numeric', timeZone: 'Asia/Manila',
    })
  : '';
---

<div
  class="timeline-item relative group pl-9 border-b border-gray-100 last:border-b-0"
  data-stop-id={completeStop.id}
  data-stop-name={completeStop.name ?? locationName ?? ''}
  data-stop-type={stopType ?? 'activity'}
  data-location-name={locationName ?? ''}
  data-scheduled-start={completeStop.scheduled_start ?? ''}
  data-scheduled-end={completeStop.scheduled_end ?? ''}
  data-waiting-time={waitingTime}
  data-notes={completeStop.notes ?? ''}
>
  <!-- Timeline Dot (colored per stop type) -->
  <div class={`absolute left-[-5px] top-4 w-2 h-2 ${colors.dot} rounded-full border-2 border-white z-10`}></div>

  <!-- Row -->
  <div class="stop-card py-3">

    <!-- View Mode -->
    <div class="view-mode">
      <div class="flex items-start justify-between gap-3">

        <!-- Left: type + name -->
        <div class="flex-1 min-w-0">
          <span class={`text-xs font-semibold ${colors.text} uppercase tracking-wide`}>
            {stopType?.replace(/_/g, ' ')}
          </span>
          {locationName && (
            <p class="font-semibold text-gray-900 text-base leading-snug mt-0.5">{locationName}</p>
          )}
          {waitingTime > 0 && (
            <span class="inline-flex items-center gap-1 mt-1 text-xs font-medium text-gray-400">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {waitingTime} min
            </span>
          )}
          {isMultiDay && (
            <span class="inline-flex items-center gap-1 mt-1.5 px-2 py-0.5 rounded-full bg-amber-50 border border-amber-200 text-xs font-semibold text-amber-600">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              ends {endDayLabel}
            </span>
          )}
        </div>

        <!-- Right: time + edit controls -->
        <div class="flex items-center gap-1.5 shrink-0">
          {stopTime && (
            <span class="text-sm font-medium text-gray-400 tabular-nums">{stopTime}</span>
          )}
          {isOwner && (
            <div class="edit-controls hidden gap-0.5">
              <button class="edit-stop-btn p-1.5 hover:bg-gray-100 rounded-lg transition-colors" title="Edit stop">
                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>
              <button class="delete-stop-btn p-1.5 hover:bg-red-50 rounded-lg transition-colors" title="Delete stop">
                <svg class="w-3.5 h-3.5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          )}
        </div>
      </div>

      {completeStop.notes && (
        <p class="text-xs text-gray-400 italic mt-2 leading-relaxed">{completeStop.notes}</p>
      )}

      <ActivityList
        activities={(completeStop as ItineraryStop)?.activities ?? []}
        stopId={completeStop.id}
        isOwner={isOwner}
      />
    </div>

    <!-- Edit Mode (populated by JS) -->
    <div class="edit-mode hidden"></div>
  </div>
</div>
