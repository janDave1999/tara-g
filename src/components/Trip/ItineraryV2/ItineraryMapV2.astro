---
import StopModalV2 from './StopModalV2.astro';

interface StopData {
  id: string;
  location_type: string;
  location_name: string;
  scheduled_start: string | null;
  order_index: number;
  location?: {
    name: string;
  };
}

interface Props {
  tripId: string;
  stops: StopData[];
  canEdit: boolean;
  tripDetails?: unknown;
}

const { tripId, stops, canEdit, tripDetails } = Astro.props;

const stopsJson = JSON.stringify(stops);
const tripDetailsJson = JSON.stringify(tripDetails || {});
---

<div
  id="itinerary-map-v2"
  class="flex h-screen w-full overflow-hidden"
  data-trip-id={tripId}
  data-stops={stopsJson}
  data-trip-details={tripDetailsJson}
  data-can-edit={canEdit.toString()}
>
  <!-- ── Map side ──────────────────────────────────────────────────── -->
  <div class="flex-1 relative h-full min-w-0">
    <div id="map-container-v2" class="h-full w-full"></div>

    <!-- Floating Header -->
    <div class="absolute top-0 left-0 right-0 z-10 p-4">
      <div class="flex items-center gap-3">
        <a href={`/trips/${tripId}`} class="btn btn-circle btn-sm bg-white shadow-lg hover:bg-gray-50">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <div id="location-search-container" class="flex-1 relative">
          <input
            type="text"
            id="location-search-input-v2"
            placeholder="🔍 Search places..."
            class="input input-sm w-full bg-white shadow-lg rounded-full text-sm"
            autocomplete="off"
          />
        </div>
        <a href={`/trips/${tripId}/itinerary`} class="btn btn-circle btn-sm bg-white shadow-lg hover:bg-gray-50" title="Switch to Mapbox">
          <span class="text-xs font-bold text-gray-600">M</span>
        </a>
      </div>
    </div>

    <!-- Route Selector -->
    <div class="absolute top-20 left-4 z-10">
      <div class="flex bg-white rounded-xl shadow-lg overflow-hidden" id="route-selector-v2" data-route-profile="DRIVING">
        <button class="route-profile-btn-v2 flex flex-col items-center gap-0.5 px-3 py-2 text-blue-600 bg-blue-50 border-b-2 border-blue-600 transition-all" data-profile="DRIVING" title="Drive">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.85 7h10.29l1.08 3.11H5.77L6.85 7zM19 17H5v-5h14v5zM7.5 14a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm9 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/></svg>
          <span class="text-[10px] font-medium">Drive</span>
        </button>
        <button class="route-profile-btn-v2 flex flex-col items-center gap-0.5 px-3 py-2 text-gray-500 hover:bg-gray-50 border-b-2 border-transparent transition-all" data-profile="TWO_WHEELER" title="Motorcycle">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 7c0-1.1-.9-2-2-2h-3l2 4h-3.5l-1-1H9l-1 1H5.8L4 7H2v2h1.2l1.8 2H3c-1.1 0-2 .9-2 2v3h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-3c0-1.1-.9-2-2-2h-1L19 7zm-13 8c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm10 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>
          <span class="text-[10px] font-medium">Moto</span>
        </button>
        <button class="route-profile-btn-v2 flex flex-col items-center gap-0.5 px-3 py-2 text-gray-500 hover:bg-gray-50 border-b-2 border-transparent transition-all" data-profile="TRANSIT" title="Transit">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c-4 0-8 .5-8 4v9.5C4 17.43 5.57 19 7.5 19L6 20.5v.5h2.23l2-2H14l2 2h2v-.5L16.5 19c1.93 0 3.5-1.57 3.5-3.5V6c0-3.5-3.58-4-8-4zm0 2c3.51 0 5.5.48 6 1.75V8H6V5.75C6.5 4.48 8.49 4 12 4zm-4 9.5c-.83 0-1.5-.67-1.5-1.5S7.17 10.5 8 10.5s1.5.67 1.5 1.5S8.83 13.5 8 13.5zm8 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM6 16.5V10h12v6.5H6z"/></svg>
          <span class="text-[10px] font-medium">Transit</span>
        </button>
        <button class="route-profile-btn-v2 flex flex-col items-center gap-0.5 px-3 py-2 text-gray-500 hover:bg-gray-50 border-b-2 border-transparent transition-all" data-profile="WALKING" title="Walk">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"/></svg>
          <span class="text-[10px] font-medium">Walk</span>
        </button>
      </div>
    </div>

    <!-- Day Tabs (mobile floating, hidden on md+) -->
    <div class="md:hidden absolute top-20 right-4 z-10">
      <div id="day-tabs-v2" class="flex gap-1 bg-white rounded-lg shadow-lg p-1 overflow-x-auto max-w-[200px] scrollbar-hide"></div>
    </div>

    <!-- Empty State -->
    {stops.length === 0 && (
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="text-center bg-white/90 p-6 rounded-2xl shadow-lg">
          <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-700 mb-1">No stops yet</h3>
          <p class="text-sm text-gray-500">
            {canEdit ? 'Search or tap map to add stops' : 'No stops added yet'}
          </p>
        </div>
      </div>
    )}

    <!-- Bottom Sheet (mobile only) -->
    <div
      id="bottom-sheet"
      class="md:hidden absolute bottom-0 left-0 right-0 bg-white rounded-t-2xl shadow-2xl z-20"
      style="height: 60px; overflow: hidden; transition: height 0.3s ease;"
    >
      <div id="bottom-sheet-handle" class="w-full h-4 flex items-center justify-center cursor-pointer pt-2">
        <div class="w-12 h-1 bg-gray-300 rounded-full"></div>
      </div>
      <div class="px-4 pb-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-semibold text-gray-900">🗺️ {stops.length} Stops</h3>
        </div>
        <div
          id="bottom-sheet-content"
          class="space-y-2 overflow-y-auto max-h-[50vh] transition-opacity duration-200"
          style="opacity: 0;"
        ></div>
      </div>
    </div>
  </div>

  <!-- ── Desktop Timeline Panel (hidden on mobile) ─────────────────── -->
  <div id="timeline-panel-v2" class="hidden md:flex flex-col w-[360px] border-l bg-white overflow-hidden flex-shrink-0">
    <!-- Panel Header -->
    <div class="flex-shrink-0 px-4 pt-4 pb-3 border-b bg-white">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-gray-900">Itinerary</h2>
        {canEdit && (
          <button id="desktop-add-stop-btn" class="btn btn-primary btn-xs">+ Add Stop</button>
        )}
      </div>
      <!-- Day Tabs (desktop) -->
      <div id="day-tabs-v2-desktop" class="flex gap-1 overflow-x-auto pb-1 scrollbar-hide"></div>
    </div>
    <!-- Timeline Content -->
    <div id="timeline-content" class="flex-1 overflow-y-auto p-3 space-y-1.5"></div>
  </div>

  <!-- Stop Modal -->
  {canEdit && (
    <StopModalV2 tripId={tripId} />
  )}
</div>

<script is:inline define:vars={{ PUBLIC_GOOGLE_MAPS_KEY: import.meta.env.PUBLIC_GOOGLE_MAPS_KEY }}>
  window.PUBLIC_GOOGLE_MAPS_KEY = PUBLIC_GOOGLE_MAPS_KEY;
</script>

<script>
  import { initItineraryMapV2 } from '@/scripts/Itinerary/ItineraryMapV2';

  document.addEventListener('DOMContentLoaded', () => {
    initItineraryMapV2();
  });

  document.addEventListener('astro:page-load', () => {
    initItineraryMapV2();
  });
</script>

<style is:global>
  #map-container-v2 {
    pointer-events: auto;
  }
  #location-search-input-v2 {
    pointer-events: auto;
  }
  #bottom-sheet-handle {
    pointer-events: auto;
  }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .timeline-stop-card[draggable="true"]:active { opacity: 0.7; }
</style>
