---
import { PUBLIC_R2_URL } from "astro:env/client";

interface FeedPost {
  post_id: string;
  author_auth_id: string;
  author_username: string;
  author_full_name: string;
  author_avatar: string | null;
  trip_id: string | null;
  trip_title: string | null;
  post_type: string;
  title: string | null;
  content: string;
  hashtags: string[];
  location_name: string | null;
  like_count: number;
  comment_count: number;
  share_count: number;
  created_at: string;
  is_liked_by_viewer: boolean;
  media_urls: string[];
}

interface Props {
  post: FeedPost;
}

const { post } = Astro.props;

const avatarSrc = post.author_avatar
  ? post.author_avatar.startsWith("http")
    ? post.author_avatar
    : `${PUBLIC_R2_URL}${post.author_avatar}`
  : null;

const photos = (post.media_urls ?? []).map((key: string) =>
  key.startsWith("http") ? key : `${PUBLIC_R2_URL}${key}`
);

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins  = Math.floor(diff / 60000);
  if (mins < 1)   return "just now";
  if (mins < 60)  return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)   return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 7)   return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString("en-PH", { month: "short", day: "numeric" });
}

const MAX_CONTENT = 280;
const isLong = post.content.length > MAX_CONTENT;
const preview = isLong ? post.content.slice(0, MAX_CONTENT) + "…" : post.content;

const liked = post.is_liked_by_viewer ?? false;
---

<article
  class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 space-y-3"
  data-post-id={post.post_id}
>
  <!-- Author row -->
  <div class="flex items-center gap-3">
    <a href={`/profile/${post.author_username}`} class="flex-shrink-0">
      {avatarSrc ? (
        <img
          src={avatarSrc}
          alt={post.author_full_name}
          class="w-10 h-10 rounded-full object-cover"
        />
      ) : (
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-indigo-500 flex items-center justify-center text-white font-semibold text-sm">
          {post.author_full_name.charAt(0).toUpperCase()}
        </div>
      )}
    </a>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <a href={`/profile/${post.author_username}`} class="font-semibold text-gray-900 text-sm hover:underline truncate">
          {post.author_full_name}
        </a>
        <span class="text-gray-400 text-xs">@{post.author_username}</span>
        <span class="text-gray-300 text-xs">·</span>
        <span class="text-gray-400 text-xs">{timeAgo(post.created_at)}</span>
      </div>
      <span class="inline-block mt-0.5 text-xs font-medium px-2 py-0.5 rounded-full bg-green-100 text-green-700">
        Trip Post
      </span>
    </div>
  </div>

  <!-- Trip link badge -->
  {post.trip_id && post.trip_title && (
    <a
      href={`/trips/${post.trip_id}`}
      class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full hover:bg-blue-100 transition"
    >
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {post.trip_title}
    </a>
  )}

  <!-- Post body -->
  <div class="space-y-1.5">
    {post.title && (
      <a href={`/post/${post.post_id}`} class="block font-semibold text-gray-900 hover:underline">
        {post.title}
      </a>
    )}

    <p
      class="text-gray-700 text-sm leading-relaxed"
      data-full={isLong ? post.content : undefined}
      data-preview={isLong ? preview : undefined}
    >
      {preview}
    </p>

    {isLong && (
      <button
        class="text-blue-600 text-xs font-medium hover:underline see-more-btn"
        type="button"
      >
        See more
      </button>
    )}

    {post.location_name && (
      <p class="flex items-center gap-1 text-gray-400 text-xs">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
        {post.location_name}
      </p>
    )}
  </div>

  <!-- Photo grid -->
  {photos.length === 1 && (
    <div class="rounded-xl overflow-hidden">
      <img src={photos[0]} alt="post photo" class="w-full max-h-80 object-cover" loading="lazy" />
    </div>
  )}
  {photos.length === 2 && (
    <div class="grid grid-cols-2 gap-1 rounded-xl overflow-hidden">
      {photos.map((src) => (
        <img src={src} alt="post photo" class="w-full h-48 object-cover" loading="lazy" />
      ))}
    </div>
  )}
  {photos.length === 3 && (
    <div class="grid grid-cols-2 gap-1 rounded-xl overflow-hidden">
      <img src={photos[0]} alt="post photo" class="w-full h-48 object-cover row-span-2" loading="lazy" />
      <img src={photos[1]} alt="post photo" class="w-full h-[93px] object-cover" loading="lazy" />
      <img src={photos[2]} alt="post photo" class="w-full h-[93px] object-cover" loading="lazy" />
    </div>
  )}
  {photos.length >= 4 && (
    <div class="grid grid-cols-2 gap-1 rounded-xl overflow-hidden">
      {photos.slice(0, 4).map((src) => (
        <img src={src} alt="post photo" class="w-full h-40 object-cover" loading="lazy" />
      ))}
    </div>
  )}

  <!-- Hashtags -->
  {post.hashtags?.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {post.hashtags.map((tag) => (
        <a
          href={`/search?q=%23${tag}`}
          class="text-blue-500 text-xs font-medium hover:underline"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}

  <!-- Action bar -->
  <div class="flex items-center gap-5 pt-1 border-t border-gray-50">

    <!-- Like button -->
    <button
      type="button"
      class="like-btn flex items-center gap-1.5 text-sm transition"
      data-post-id={post.post_id}
      data-liked={liked ? "true" : "false"}
      data-like-count={post.like_count}
    >
      {liked ? (
        <svg class="like-icon w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
      ) : (
        <svg class="like-icon w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      )}
      <span class={`like-count text-xs ${liked ? "text-red-500" : "text-gray-500"}`}>
        {post.like_count > 0 ? post.like_count : ""}
      </span>
    </button>

    <!-- Comment button -->
    <button
      type="button"
      class="comment-btn flex items-center gap-1.5 text-gray-500 hover:text-blue-500 text-sm transition"
      data-post-id={post.post_id}
      data-author={post.author_full_name}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="comment-count text-xs">{post.comment_count > 0 ? post.comment_count : ""}</span>
    </button>

    <!-- Share -->
    <button
      type="button"
      class="share-btn flex items-center gap-1.5 text-gray-500 hover:text-green-500 text-sm transition"
      data-post-id={post.post_id}
      data-title={post.title ?? `${post.author_full_name} on Tara-G`}
      data-content={post.content}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
      </svg>
      <span class="share-count text-xs">{post.share_count > 0 ? post.share_count : ""}</span>
    </button>
  </div>
</article>

<script>
  import { actions } from "astro:actions";
  import { showToast } from "@/scripts/Toast";

  // --- See more toggle ---
  document.querySelectorAll<HTMLButtonElement>(".see-more-btn").forEach((btn) => {
    const p = btn.previousElementSibling as HTMLParagraphElement;
    if (!p) return;
    btn.addEventListener("click", () => {
      if (p.dataset.full) {
        p.textContent = p.dataset.full;
        btn.textContent = "See less";
        delete p.dataset.full;
      } else {
        p.textContent = p.dataset.preview ?? "";
        btn.textContent = "See more";
      }
    });
  });

  // --- Like toggle (optimistic) ---
  document.querySelectorAll<HTMLButtonElement>(".like-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const postId    = btn.dataset.postId!;
      const isLiked   = btn.dataset.liked === "true";
      const count     = parseInt(btn.dataset.likeCount ?? "0", 10);
      const icon      = btn.querySelector<SVGElement>(".like-icon")!;
      const countSpan = btn.querySelector<HTMLSpanElement>(".like-count")!;

      const newLiked = !isLiked;
      const newCount = newLiked ? count + 1 : Math.max(0, count - 1);

      // Optimistic update
      applyLikeState(btn, icon, countSpan, newLiked, newCount);

      const res = await actions.feed.toggleLike({ postId });

      if (res.error) {
        // Revert on failure
        applyLikeState(btn, icon, countSpan, isLiked, count);
        showToast({ message: "Could not update like. Try again.", type: "error" });
        return;
      }

      // Sync confirmed count from server
      const confirmed = res.data!.newLikeCount;
      btn.dataset.likeCount = String(confirmed);
      countSpan.textContent = confirmed > 0 ? String(confirmed) : "";
    });
  });

  function applyLikeState(
    btn: HTMLButtonElement,
    icon: SVGElement,
    countSpan: HTMLSpanElement,
    liked: boolean,
    count: number
  ) {
    btn.dataset.liked     = String(liked);
    btn.dataset.likeCount = String(count);
    countSpan.textContent = count > 0 ? String(count) : "";

    if (liked) {
      icon.setAttribute("fill", "currentColor");
      icon.removeAttribute("stroke");
      icon.classList.remove("text-gray-400");
      icon.classList.add("text-red-500");
      countSpan.classList.remove("text-gray-500");
      countSpan.classList.add("text-red-500");
      icon.innerHTML = `<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />`;
    } else {
      icon.setAttribute("fill", "none");
      icon.setAttribute("stroke", "currentColor");
      icon.classList.remove("text-red-500");
      icon.classList.add("text-gray-400");
      countSpan.classList.remove("text-red-500");
      countSpan.classList.add("text-gray-500");
      icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`;
    }
  }

  // --- Comment button → open sheet ---
  document.querySelectorAll<HTMLButtonElement>(".comment-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-comments", {
        detail: {
          postId:     btn.dataset.postId,
          authorName: btn.dataset.author,
        },
      }));
    });
  });

  // --- Share ---
  document.querySelectorAll<HTMLButtonElement>(".share-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const postId  = btn.dataset.postId!;
      const title   = btn.dataset.title ?? "Check this out on Tara-G";
      const content = btn.dataset.content ?? "";
      const text    = content.slice(0, 100) + (content.length > 100 ? "…" : "");

      // 1. Generate trackable share link
      const linkRes = await actions.feed.createShareLink({ postId });
      if (linkRes.error || !linkRes.data?.shareId) return;
      const url = `${location.origin}/post/${postId}?sid=${linkRes.data.shareId}`;

      // 2. Native share sheet or clipboard fallback
      let shared = false;
      if (navigator.share) {
        try { await navigator.share({ title, text, url }); shared = true; } catch {}
      }
      if (!shared) {
        try { await navigator.clipboard.writeText(url); } catch {
          const el = document.createElement("textarea");
          el.value = url; document.body.appendChild(el); el.select();
          document.execCommand("copy"); document.body.removeChild(el);
        }
        showToast({ message: "Link copied!", type: "success" });
        shared = true;
      }
      // share_count increments when recipients open the link, not here
    });
  });

  // --- comment:posted → increment count on the card ---
  document.addEventListener("comment:posted", (e: Event) => {
    const { postId } = (e as CustomEvent).detail;
    const article = document.querySelector<HTMLElement>(`article[data-post-id="${postId}"]`);
    if (!article) return;
    const countSpan = article.querySelector<HTMLSpanElement>(".comment-count");
    if (!countSpan) return;
    const current = parseInt(countSpan.textContent || "0", 10);
    countSpan.textContent = String(current + 1);
  });
</script>
