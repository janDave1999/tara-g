---
import type { PAGE_PLATE_PROPS } from "@/types/pageplates/types";
import Layout from "./Layout.astro";
import FooterMain from "@/features/footer/FooterMain.astro";
import Header from "@/features/navbar/Header.astro";
import SeoHead from "@/seo/component/SeoHead.astro";
import CookiesConsent from "@/components/CookiesConsent.astro";
import LoadModal from "@/components/LoadModal.astro";
import MediaLightbox from "@/components/MediaLightbox.astro";
import BottomNav from "@/features/navbar/BottomNav.astro";
import { PUBLIC_R2_URL } from 'astro:env/client';

let user_id = Astro.locals.user_id;
let avatar_url = Astro.locals.avatar_url;
let user_name = Astro.locals.username;
let full_name = Astro.locals.full_name || "";
const avatarUrl = avatar_url 
  ? (avatar_url.startsWith('http') ? avatar_url : `${PUBLIC_R2_URL}${avatar_url}`)
  : "";
interface Props extends PAGE_PLATE_PROPS {}

let {
  title = "Tara G!",
  noHeader = false,
  noFooter = false,
  noContainer = false,
  clean = false,
  expectedHeight = "min-h-screen",
  prefetch,
  description,
  html = {},
  containerClass = "",
} = Astro.props;

//---> Preflight
if(description == undefined){
  description = {
    title,
    type: "WebPage",
    description: "Discover amazing trips and experiences with Tara G!",
    author: "Tara G!",
    authorIs: "Organization",
  };
}
if(description && !description.title){
  description.title = title;
}
---

<Layout title={title} html={html}>
  <Fragment slot={`head-last`}>
    <SeoHead description={description} prefetch={prefetch} showFb={!!description?.fbAppId} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Tara G!",
      "url": "https://tara-g.site",
      "logo": `${PUBLIC_R2_URL}logo-with-bg.jpg`,
      "description": "Explore the Philippines together with Tara G! - Join or create trips, connect with fellow travelers, and discover all 82 Philippine provinces.",
      "sameAs": [
        "https://www.facebook.com/taragph",
        "https://www.instagram.com/taragph"
      ]
    })} />
    <slot name="head-extra" />
  </Fragment>
    {clean?"":<>
      {noHeader ? "":<>
        <Header
          userId={user_id}
          avatarUrl={avatarUrl}
          username={Astro.locals.username}
          fullName={full_name}
        />
        <!-- Spacer so fixed header doesn't overlap content -->
        <div class="h-14 sm:h-16" aria-hidden="true"></div>
      </>}
    </>}
    <main>
    <slot name="header" />

{noContainer ?<>
      <slot />
      {user_id && <div class="h-16 md:hidden" aria-hidden="true"></div>}
      </>:<>
      <div
        class={`container mx-auto px-4 sm:px-6 md:px-8 lg:px-12 py-4 sm:py-6 md:py-8 lg:py-12 relative ${containerClass}`}
      >
      <slot />
    </div>
    {user_id && <div class="h-16 md:hidden" aria-hidden="true"></div>}
    </>}
    </main>
    <CookiesConsent />
    <LoadModal />
    {
     user_id ? <BottomNav currentPath={Astro.url.pathname} /> : ""
    }

    <MediaLightbox />

    <!-- ── Upload progress bar (Instagram-style, below header) ─── -->
    <div
      id="upload-bar-wrap"
      role="status"
      aria-live="polite"
      class="fixed top-14 sm:top-16 left-0 right-0 z-[400]
             pointer-events-none opacity-0 transition-opacity duration-300"
    >
      <!-- The filling bar -->
      <div id="upload-bar"
        class="h-1 bg-blue-500 transition-[width] duration-150 ease-out"
        style="width:0%">
      </div>
      <!-- Small status label centered below the bar -->
      <div class="flex justify-center mt-1">
        <span id="upload-label-text"
          class="text-[10px] font-semibold text-blue-700 bg-white/90 backdrop-blur-sm
                 px-2 py-0.5 rounded-full shadow-sm whitespace-nowrap opacity-80">
        </span>
      </div>
    </div>

    <script>
      const barWrap  = document.getElementById("upload-bar-wrap")!;
      const bar      = document.getElementById("upload-bar")!;
      const labelTxt = document.getElementById("upload-label-text")!;
      let hideTimer: ReturnType<typeof setTimeout>;

      function showBar() {
        clearTimeout(hideTimer);
        barWrap.classList.remove("opacity-0");
      }
      function hideAll(delayMs: number) {
        hideTimer = setTimeout(() => {
          barWrap.classList.add("opacity-0");
          setTimeout(() => { bar.style.width = "0%"; }, 350);
        }, delayMs);
      }

      document.addEventListener("upload:start", () => {
        bar.className = "h-1 bg-blue-500 transition-[width] duration-150 ease-out";
        bar.style.width = "0%";
        labelTxt.textContent = "Uploading…";
        showBar();
      });
      document.addEventListener("upload:progress", (e: Event) => {
        const pct = (e as CustomEvent<number>).detail;
        bar.style.width = `${pct}%`;
        labelTxt.textContent = `Uploading… ${pct}%`;
      });
      document.addEventListener("upload:done", () => {
        bar.style.width = "100%";
        labelTxt.textContent = "Post shared!";
        hideAll(1800);
      });
      document.addEventListener("upload:error", () => {
        bar.className = "h-1 bg-red-500 transition-[width] duration-150 ease-out";
        bar.style.width = "100%";
        labelTxt.textContent = "Upload failed. Try again.";
        hideAll(3500);
      });
    </script>
    {clean?"": <>
      {noFooter ? "":<>
        <FooterMain />
      </>}
    </>}
</Layout>