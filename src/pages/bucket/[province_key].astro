---
import PagePlate from "@/layouts/PagePlate.astro";
import VisitModal from "@/components/Project82/VisitModal.astro";
import LogModal from "@/components/Project82/LogModal.astro";
import { PH_PROVINCES } from "@/data/phProvinces";
import { supabaseAdmin } from "@/lib/supabase";

const authId = Astro.locals.user_id;
const pathname = new URL(Astro.request.url).pathname;
if (!authId) return Astro.redirect("/signin?next=" + encodeURIComponent(pathname));

const { province_key } = Astro.params;
const provinceKey = province_key?.toUpperCase() ?? "";
const province = PH_PROVINCES.find(p => p.key === provinceKey);
if (!province) return Astro.redirect("/project82");

// ── Fetch visit ────────────────────────────────────────────────────────────
const { data: visitRow } = await supabaseAdmin
  .from("user_province_visits")
  .select("id, stage, visit_date, notes")
  .eq("user_id", authId)
  .eq("province_key", provinceKey)
  .maybeSingle();

const visit = visitRow ?? null;

// ── Fetch travel logs ──────────────────────────────────────────────────────
const { data: logsRows } = await supabaseAdmin
  .from("province_travel_logs")
  .select("id, title, description, activity_type, location, visited_at, trip_id, created_at, updated_at")
  .eq("user_id", authId)
  .eq("province_key", provinceKey)
  .order("visited_at", { ascending: false, nullsFirst: false })
  .order("created_at", { ascending: false });

const rawLogs = logsRows ?? [];

// ── Pre-fetch trip titles ──────────────────────────────────────────────────
const tripIds = [...new Set(rawLogs.map(l => l.trip_id).filter(Boolean))] as string[];
const tripTitleMap: Record<string, string> = {};
if (tripIds.length > 0) {
  const { data: tripRows } = await supabaseAdmin
    .from("trips")
    .select("trip_id, title")
    .in("trip_id", tripIds);
  for (const t of tripRows ?? []) tripTitleMap[t.trip_id] = t.title;
}

// ── Pre-fetch posts per trip ───────────────────────────────────────────────
const postsByTrip: Record<string, { post_id: string; title: string | null; content: string }[]> = {};
if (tripIds.length > 0) {
  const { data: userRow } = await supabaseAdmin
    .from("users").select("user_id").eq("auth_id", authId).single();
  if (userRow?.user_id) {
    const { data: postRows } = await supabaseAdmin
      .from("user_posts")
      .select("post_id, trip_id, title, content")
      .in("trip_id", tripIds)
      .eq("user_id", userRow.user_id)
      .order("created_at", { ascending: false });
    for (const p of postRows ?? []) {
      if (!postsByTrip[p.trip_id]) postsByTrip[p.trip_id] = [];
      postsByTrip[p.trip_id].push(p);
    }
  }
}

// ── Pre-compute display data for every log ─────────────────────────────────
function fmtDatetime(iso: string | null | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleDateString("en-PH", {
    year: "numeric", month: "short", day: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}

function fmtDate(iso: string | null | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleDateString("en-PH", { year: "numeric", month: "short", day: "numeric" });
}

const logs = rawLogs.map(log => ({
  ...log,
  tripTitle:  log.trip_id ? (tripTitleMap[log.trip_id] ?? null) : null,
  tripPosts:  log.trip_id ? (postsByTrip[log.trip_id] ?? [])   : [],
  fmtDatetime: fmtDatetime(log.visited_at),
}));

const STAGE_LABELS: Record<string, string> = {
  pass_through:         "Pass Through",
  short_stay:           "Short Stay",
  extended_stay:        "Extended Stay",
  thorough_exploration: "Thorough Exploration",
};
const STAGE_COLORS: Record<string, string> = {
  pass_through:         "bg-blue-100 text-blue-700",
  short_stay:           "bg-yellow-100 text-yellow-700",
  extended_stay:        "bg-orange-100 text-orange-700",
  thorough_exploration: "bg-red-100 text-red-700",
};
const TYPE_LABELS: Record<string, string> = {
  sightseeing:   "Sightseeing",   dining:        "Dining",
  shopping:      "Shopping",      entertainment: "Entertainment",
  adventure:     "Adventure",     cultural:      "Cultural",
  relaxation:    "Relaxation",    other:         "Other",
};
const TYPE_COLORS: Record<string, string> = {
  sightseeing:   "bg-sky-100 text-sky-700",
  dining:        "bg-amber-100 text-amber-700",
  shopping:      "bg-pink-100 text-pink-700",
  entertainment: "bg-purple-100 text-purple-700",
  adventure:     "bg-emerald-100 text-emerald-700",
  cultural:      "bg-indigo-100 text-indigo-700",
  relaxation:    "bg-teal-100 text-teal-700",
  other:         "bg-gray-100 text-gray-600",
};
---

<PagePlate
  title={`${province.name} — Tara G!`}
  description={{
    title: `${province.name} — Tara G!`,
    description: `Travel logs for ${province.name}, Region ${province.region}.`,
    author: "Tara G!",
    authorIs: "Organization",
  }}
>
  <div class="max-w-lg mx-auto px-4 py-6 space-y-6">

    <!-- Back + Header -->
    <div class="flex items-center gap-3">
      <a href="/project82" class="shrink-0 text-gray-400 hover:text-gray-600 transition-colors">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <div class="flex-1 min-w-0">
        <h1 class="text-xl font-bold text-gray-900 truncate">{province.name}</h1>
        <p class="text-xs text-gray-400">Region {province.region}</p>
      </div>
      {visit && (
        <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${STAGE_COLORS[visit.stage] ?? "bg-gray-100 text-gray-600"}`}>
          {STAGE_LABELS[visit.stage] ?? visit.stage}
        </span>
      )}
    </div>

    <!-- Visit card -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">My Visit</p>
        <button id="edit-visit-btn" class="text-xs text-emerald-600 font-semibold hover:text-emerald-700">
          {visit ? "Edit" : "+ Log Visit"}
        </button>
      </div>
      {visit ? (
        <div class="px-4 py-3 space-y-1.5">
          <div class="flex items-center gap-2 flex-wrap">
            <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${STAGE_COLORS[visit.stage] ?? "bg-gray-100 text-gray-500"}`}>
              {STAGE_LABELS[visit.stage] ?? visit.stage}
            </span>
            {visit.visit_date && (
              <span class="text-xs text-gray-400">{fmtDate(visit.visit_date)}</span>
            )}
          </div>
          {visit.notes && (
            <p class="text-sm text-gray-500 leading-relaxed">{visit.notes}</p>
          )}
        </div>
      ) : (
        <p class="px-4 py-5 text-center text-sm text-gray-400">You haven't logged a visit here yet.</p>
      )}
    </div>

    <!-- Travel Logs -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <p class="text-sm font-bold text-gray-700">
          Travel Logs
          {logs.length > 0 && (
            <span id="log-count-badge" class="ml-1.5 text-xs font-normal text-gray-400">({logs.length})</span>
          )}
        </p>
        <button id="add-log-btn" class="flex items-center gap-1 text-xs font-semibold text-sky-600 hover:text-sky-700">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
          </svg>
          Add Log
        </button>
      </div>

      <div id="log-list" class="space-y-2">
        {logs.length === 0 && (
          <div id="log-empty" class="text-center py-10 text-sm text-gray-400 bg-white rounded-2xl border border-dashed border-gray-200">
            No travel logs yet.<br/>
            <span class="text-xs">Tap "Add Log" to start.</span>
          </div>
        )}
        {logs.map(log => (
          <div class="log-card bg-white rounded-2xl border border-gray-100 shadow-sm px-4 py-3 space-y-2" data-log-id={log.id}>
            <!-- Title + edit button -->
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-800">{log.title}</p>
                <span class={`inline-block mt-0.5 text-[10px] font-semibold px-1.5 py-0.5 rounded-full ${TYPE_COLORS[log.activity_type] ?? "bg-gray-100 text-gray-600"}`}>
                  {TYPE_LABELS[log.activity_type] ?? log.activity_type}
                </span>
              </div>
              <button
                class="edit-log-btn shrink-0 p-1 text-gray-300 hover:text-gray-500 transition-colors"
                data-log={JSON.stringify(log)}
                aria-label="Edit log"
              >
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </button>
            </div>

            <!-- Location + datetime -->
            {(log.location || log.fmtDatetime) && (
              <div class="flex flex-wrap gap-3 text-[11px] text-gray-400">
                {log.location && (
                  <span class="flex items-center gap-1">
                    <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {log.location}
                  </span>
                )}
                {log.fmtDatetime && (
                  <span class="flex items-center gap-1">
                    <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {log.fmtDatetime}
                  </span>
                )}
              </div>
            )}

            <!-- Notes -->
            {log.description && (
              <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">{log.description}</p>
            )}

            <!-- Linked trip + posts -->
            {log.tripTitle && (
              <div class="pt-1.5 border-t border-gray-100 space-y-1">
                <a href={`/trips/${log.trip_id}`} class="flex items-center gap-1.5 text-[11px] text-sky-600 hover:text-sky-700 font-medium">
                  <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                  </svg>
                  {log.tripTitle}
                </a>
                {log.tripPosts.map(post => (
                  <a href={`/posts/${post.post_id}`} class="flex items-start gap-1.5 text-[11px] text-gray-500 hover:text-gray-700">
                    <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="mt-0.5 shrink-0">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="line-clamp-1">{post.title ?? post.content.slice(0, 60)}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

  </div>

  <VisitModal />
  <LogModal />
</PagePlate>

<script define:vars={{ province, visit, provinceKeyStr: province.key }} is:inline>
  // ── Visit edit button ──────────────────────────────────────────────────
  document.getElementById('edit-visit-btn')?.addEventListener('click', () => {
    window.openVisitModal({
      id:              visit?.id,
      province_key:    province.key,
      province_name:   province.name,
      province_region: 'Region ' + province.region,
      stage:           visit?.stage,
      visit_date:      visit?.visit_date ?? null,
      notes:           visit?.notes ?? null,
    });
  });

  window.addEventListener('province-visit-saved',   () => window.location.reload());
  window.addEventListener('province-visit-deleted', () => window.location.reload());

  // ── Log helpers ────────────────────────────────────────────────────────
  var TYPE_LABELS = {
    sightseeing:'Sightseeing', dining:'Dining', shopping:'Shopping',
    entertainment:'Entertainment', adventure:'Adventure',
    cultural:'Cultural', relaxation:'Relaxation', other:'Other',
  };
  var TYPE_COLORS = {
    sightseeing:   'bg-sky-100 text-sky-700',
    dining:        'bg-amber-100 text-amber-700',
    shopping:      'bg-pink-100 text-pink-700',
    entertainment: 'bg-purple-100 text-purple-700',
    adventure:     'bg-emerald-100 text-emerald-700',
    cultural:      'bg-indigo-100 text-indigo-700',
    relaxation:    'bg-teal-100 text-teal-700',
    other:         'bg-gray-100 text-gray-600',
  };

  function fmtDt(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return isNaN(d.getTime()) ? '' : d.toLocaleDateString('en-PH', {
      year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'
    });
  }

  function openEdit(log) {
    window.openLogModal({
      id:            log.id,
      province_key:  province.key,
      province_name: province.name,
      title:         log.title,
      description:   log.description,
      activity_type: log.activity_type,
      location:      log.location,
      visited_at:    log.visited_at,
      trip_id:       log.trip_id,
    });
  }

  function buildLogCard(log) {
    var colorClass = TYPE_COLORS[log.activity_type] || 'bg-gray-100 text-gray-600';
    var typeLabel  = TYPE_LABELS[log.activity_type] || log.activity_type;
    var dt         = fmtDt(log.visited_at);
    var tripTitle  = log._trip_title || null;

    var metaHtml = (log.location || dt) ? '<div class="flex flex-wrap gap-3 text-[11px] text-gray-400">'
      + (log.location ? '<span class="flex items-center gap-1"><svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>' + log.location + '</span>' : '')
      + (dt ? '<span class="flex items-center gap-1"><svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' + dt + '</span>' : '')
      + '</div>' : '';

    var tripHtml = tripTitle ? '<div class="pt-1.5 border-t border-gray-100"><a href="/trips/' + log.trip_id + '" class="flex items-center gap-1.5 text-[11px] text-sky-600 font-medium">'
      + '<svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>'
      + tripTitle + '</a></div>' : '';

    var div = document.createElement('div');
    div.className = 'log-card bg-white rounded-2xl border border-gray-100 shadow-sm px-4 py-3 space-y-2';
    div.dataset.logId = log.id;
    div.innerHTML =
      '<div class="flex items-start justify-between gap-2">'
        + '<div class="flex-1 min-w-0">'
          + '<p class="text-sm font-semibold text-gray-800">' + log.title + '</p>'
          + '<span class="inline-block mt-0.5 text-[10px] font-semibold px-1.5 py-0.5 rounded-full ' + colorClass + '">' + typeLabel + '</span>'
        + '</div>'
        + '<button class="edit-log-btn shrink-0 p-1 text-gray-300 hover:text-gray-500 transition-colors" aria-label="Edit log">'
          + '<svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>'
        + '</button>'
      + '</div>'
      + metaHtml
      + (log.description ? '<p class="text-xs text-gray-500 leading-relaxed line-clamp-2">' + log.description + '</p>' : '')
      + tripHtml;

    div.querySelector('.edit-log-btn').addEventListener('click', function() { openEdit(log); });
    return div;
  }

  function updateCount(delta) {
    var badge = document.getElementById('log-count-badge');
    var list  = document.getElementById('log-list');
    if (!list) return;
    var current = badge ? parseInt(badge.textContent.replace(/\D/g,'') || '0') : 0;
    var next = current + delta;
    if (badge) {
      if (next <= 0) badge.remove();
      else badge.textContent = '(' + next + ')';
    } else if (next > 0) {
      var s = document.createElement('span');
      s.id = 'log-count-badge';
      s.className = 'ml-1.5 text-xs font-normal text-gray-400';
      s.textContent = '(' + next + ')';
      var h = list.previousElementSibling && list.previousElementSibling.querySelector('p');
      if (h) h.appendChild(s);
    }
  }

  // ── Add log button ─────────────────────────────────────────────────────
  document.getElementById('add-log-btn')?.addEventListener('click', function() {
    window.openLogModal({ province_key: province.key, province_name: province.name });
  });

  // Wire SSR-rendered edit buttons
  document.querySelectorAll('.edit-log-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openEdit(JSON.parse(btn.dataset.log || '{}'));
    });
  });

  // ── Live log events ────────────────────────────────────────────────────
  window.addEventListener('province-log-created', function(e) {
    var log = e.detail.log;
    document.getElementById('log-empty')?.remove();
    var list = document.getElementById('log-list');
    if (list) list.prepend(buildLogCard(log));
    updateCount(1);
  });

  window.addEventListener('province-log-updated', function(e) {
    var log = e.detail.log;
    var el = document.querySelector('[data-log-id="' + log.id + '"]');
    if (el) el.replaceWith(buildLogCard(log));
  });

  window.addEventListener('province-log-deleted', function(e) {
    var log_id = e.detail.log_id;
    var el = document.querySelector('[data-log-id="' + log_id + '"]');
    if (el) el.remove();
    updateCount(-1);
    var list = document.getElementById('log-list');
    if (list && list.children.length === 0) {
      var empty = document.createElement('div');
      empty.id = 'log-empty';
      empty.className = 'text-center py-10 text-sm text-gray-400 bg-white rounded-2xl border border-dashed border-gray-200';
      empty.innerHTML = 'No travel logs yet.<br/><span class="text-xs">Tap "Add Log" to start.</span>';
      list.appendChild(empty);
    }
  });
</script>
