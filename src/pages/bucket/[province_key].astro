---
import PagePlate from "@/layouts/PagePlate.astro";
import VisitModal from "@/components/Project82/VisitModal.astro";
import LogModal from "@/components/Project82/LogModal.astro";
import { PH_PROVINCES } from "@/data/phProvinces";
import { supabaseAdmin } from "@/lib/supabase";

const authId = Astro.locals.user_id;
const pathname = new URL(Astro.request.url).pathname;
if (!authId) return Astro.redirect("/signin?next=" + encodeURIComponent(pathname));

const { province_key } = Astro.params;
const provinceKey = province_key?.toUpperCase() ?? "";
const province = PH_PROVINCES.find(p => p.key === provinceKey);
if (!province) return Astro.redirect("/project82");

// Fetch visit
const { data: visitRow } = await supabaseAdmin
  .from("user_province_visits")
  .select("id, stage, visit_date, notes, is_auto_detected, created_at")
  .eq("user_id", authId)
  .eq("province_key", provinceKey)
  .maybeSingle();

// Fetch travel logs
const { data: logsRows } = await supabaseAdmin
  .from("province_travel_logs")
  .select("id, title, description, activity_type, location, visited_at, trip_id, created_at, updated_at")
  .eq("user_id", authId)
  .eq("province_key", provinceKey)
  .order("visited_at", { ascending: false, nullsFirst: false })
  .order("created_at", { ascending: false });

const visit = visitRow ?? null;
const logs  = logsRows ?? [];

// Batch-fetch trip titles for linked logs
const tripIds = [...new Set(logs.map(l => l.trip_id).filter(Boolean))] as string[];
const tripTitleMap = new Map<string, string>();
if (tripIds.length > 0) {
  const { data: tripRows } = await supabaseAdmin
    .from("trips")
    .select("trip_id, title")
    .in("trip_id", tripIds);
  for (const t of tripRows ?? []) tripTitleMap.set(t.trip_id, t.title);
}

// Batch-fetch posts for those trips (user_posts.user_id = internal user_id)
const postsByTrip = new Map<string, { post_id: string; title: string | null; content: string; created_at: string }[]>();
if (tripIds.length > 0) {
  const { data: userRow } = await supabaseAdmin
    .from("users")
    .select("user_id")
    .eq("auth_id", authId)
    .single();

  if (userRow?.user_id) {
    const { data: postRows } = await supabaseAdmin
      .from("user_posts")
      .select("post_id, trip_id, title, content, created_at")
      .in("trip_id", tripIds)
      .eq("user_id", userRow.user_id)
      .order("created_at", { ascending: false });

    for (const p of postRows ?? []) {
      if (!postsByTrip.has(p.trip_id)) postsByTrip.set(p.trip_id, []);
      postsByTrip.get(p.trip_id)!.push(p);
    }
  }
}

const STAGE_LABELS: Record<string, string> = {
  pass_through:         "Pass Through",
  short_stay:           "Short Stay",
  extended_stay:        "Extended Stay",
  thorough_exploration: "Thorough Exploration",
};
const STAGE_COLORS: Record<string, string> = {
  pass_through:         "bg-blue-100 text-blue-700",
  short_stay:           "bg-yellow-100 text-yellow-700",
  extended_stay:        "bg-orange-100 text-orange-700",
  thorough_exploration: "bg-red-100 text-red-700",
};
const TYPE_LABELS: Record<string, string> = {
  sightseeing:   "Sightseeing",
  dining:        "Dining",
  shopping:      "Shopping",
  entertainment: "Entertainment",
  adventure:     "Adventure",
  cultural:      "Cultural",
  relaxation:    "Relaxation",
  other:         "Other",
};
const TYPE_COLORS: Record<string, string> = {
  sightseeing:   "bg-sky-100 text-sky-700",
  dining:        "bg-amber-100 text-amber-700",
  shopping:      "bg-pink-100 text-pink-700",
  entertainment: "bg-purple-100 text-purple-700",
  adventure:     "bg-emerald-100 text-emerald-700",
  cultural:      "bg-indigo-100 text-indigo-700",
  relaxation:    "bg-teal-100 text-teal-700",
  other:         "bg-gray-100 text-gray-600",
};

function fmtDatetime(iso?: string | null) {
  if (!iso) return null;
  const d = new Date(iso);
  return d.toLocaleDateString("en-PH", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
}
---

<PagePlate
  title={`${province.name} — Tara G!`}
  description={{
    title: `${province.name} — Tara G!`,
    description: `Travel logs for ${province.name}, Region ${province.region}.`,
    author: "Tara G!",
    authorIs: "Organization",
  }}
>
  <div class="max-w-lg mx-auto px-4 py-6 space-y-6">

    <!-- Back + Header -->
    <div class="flex items-center gap-3">
      <a href="/project82" class="text-gray-400 hover:text-gray-600 transition-colors shrink-0">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <div class="flex-1 min-w-0">
        <h1 class="text-xl font-bold text-gray-900 truncate">{province.name}</h1>
        <p class="text-xs text-gray-400">Region {province.region}</p>
      </div>
      {visit && (
        <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${STAGE_COLORS[visit.stage] ?? "bg-gray-100 text-gray-600"}`}>
          {STAGE_LABELS[visit.stage] ?? visit.stage}
        </span>
      )}
    </div>

    <!-- Visit card -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-50 flex items-center justify-between">
        <h2 class="text-xs font-bold text-gray-500 uppercase tracking-wide">My Visit</h2>
        <button
          id="edit-visit-btn"
          class="text-xs text-emerald-600 font-semibold hover:text-emerald-700 transition-colors"
        >
          {visit ? "Edit" : "+ Log Visit"}
        </button>
      </div>
      {visit ? (
        <div class="px-4 py-3 space-y-1.5">
          <div class="flex items-center gap-2 flex-wrap">
            <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${STAGE_COLORS[visit.stage] ?? "bg-gray-100 text-gray-500"}`}>
              {STAGE_LABELS[visit.stage] ?? visit.stage}
            </span>
            {visit.visit_date && (
              <span class="text-xs text-gray-400">
                {new Date(visit.visit_date).toLocaleDateString("en-PH", { year: "numeric", month: "short", day: "numeric" })}
              </span>
            )}
          </div>
          {visit.notes && <p class="text-sm text-gray-500 leading-relaxed">{visit.notes}</p>}
        </div>
      ) : (
        <div class="px-4 py-5 text-center text-sm text-gray-400">
          You haven't logged a visit here yet.
        </div>
      )}
    </div>

    <!-- Travel Logs -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-bold text-gray-700">
          Travel Logs
          {logs.length > 0 && (
            <span id="log-count-badge" class="ml-1.5 text-xs font-normal text-gray-400">({logs.length})</span>
          )}
        </h2>
        <button
          id="add-log-btn"
          class="flex items-center gap-1 text-xs font-semibold text-sky-600 hover:text-sky-700 transition-colors"
        >
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
          </svg>
          Add Log
        </button>
      </div>

      <div id="log-list" class="space-y-2">
        {logs.length === 0 ? (
          <div id="log-empty" class="text-center py-10 text-sm text-gray-400 bg-white rounded-2xl border border-dashed border-gray-200">
            No travel logs yet.<br/>
            <span class="text-xs">Tap "Add Log" to start.</span>
          </div>
        ) : logs.map(log => {
          const tripTitle = log.trip_id ? tripTitleMap.get(log.trip_id) : null;
          const tripPosts = log.trip_id ? (postsByTrip.get(log.trip_id) ?? []) : [];
          return (
            <div
              class="log-card bg-white rounded-2xl border border-gray-100 shadow-sm px-4 py-3 space-y-2"
              data-log-id={log.id}
            >
              <!-- Title row -->
              <div class="flex items-start justify-between gap-2">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-800">{log.title}</p>
                  <div class="flex items-center gap-2 mt-0.5 flex-wrap">
                    <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded-full ${TYPE_COLORS[log.activity_type] ?? "bg-gray-100 text-gray-600"}`}>
                      {TYPE_LABELS[log.activity_type] ?? log.activity_type}
                    </span>
                  </div>
                </div>
                <button
                  class="edit-log-btn shrink-0 p-1 text-gray-300 hover:text-gray-500 transition-colors"
                  data-log={JSON.stringify({ ...log, _trip_title: tripTitle })}
                  aria-label="Edit log"
                >
                  <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                </button>
              </div>

              <!-- Meta row: location · datetime -->
              {(log.location || log.visited_at) && (
                <div class="flex items-center gap-3 text-[11px] text-gray-400 flex-wrap">
                  {log.location && (
                    <span class="flex items-center gap-1">
                      <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      {log.location}
                    </span>
                  )}
                  {log.visited_at && (
                    <span class="flex items-center gap-1">
                      <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                      {fmtDatetime(log.visited_at)}
                    </span>
                  )}
                </div>
              )}

              <!-- Notes -->
              {log.description && (
                <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">{log.description}</p>
              )}

              <!-- Linked trip -->
              {tripTitle && (
                <div class="pt-1 border-t border-gray-50 space-y-1.5">
                  <a
                    href={`/trips/${log.trip_id}`}
                    class="flex items-center gap-1.5 text-[11px] text-sky-600 hover:text-sky-700 font-medium transition-colors"
                  >
                    <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    {tripTitle}
                  </a>

                  {tripPosts.length > 0 && (
                    <div class="space-y-1">
                      {tripPosts.map(post => (
                        <a
                          href={`/posts/${post.post_id}`}
                          class="flex items-start gap-1.5 text-[11px] text-gray-500 hover:text-gray-700 transition-colors"
                        >
                          <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="mt-0.5 shrink-0">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          <span class="line-clamp-1">{post.title ?? post.content.slice(0, 60)}</span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

  </div>

  <VisitModal />
  <LogModal />
</PagePlate>

<script define:vars={{ province, visit, provinceKeyStr: province.key }} is:inline>
  // ── Visit ──────────────────────────────────────────────────────────────
  document.getElementById('edit-visit-btn')?.addEventListener('click', () => {
    (window).openVisitModal({
      id:              visit?.id,
      province_key:    province.key,
      province_name:   province.name,
      province_region: `Region ${province.region}`,
      stage:           visit?.stage,
      visit_date:      visit?.visit_date ?? null,
      notes:           visit?.notes ?? null,
    });
  });

  window.addEventListener('province-visit-saved',   () => window.location.reload());
  window.addEventListener('province-visit-deleted', () => window.location.reload());

  // ── Log helpers ────────────────────────────────────────────────────────
  const TYPE_LABELS = {
    sightseeing:'Sightseeing', dining:'Dining', shopping:'Shopping',
    entertainment:'Entertainment', adventure:'Adventure',
    cultural:'Cultural', relaxation:'Relaxation', other:'Other',
  };
  const TYPE_COLORS = {
    sightseeing:   'bg-sky-100 text-sky-700',
    dining:        'bg-amber-100 text-amber-700',
    shopping:      'bg-pink-100 text-pink-700',
    entertainment: 'bg-purple-100 text-purple-700',
    adventure:     'bg-emerald-100 text-emerald-700',
    cultural:      'bg-indigo-100 text-indigo-700',
    relaxation:    'bg-teal-100 text-teal-700',
    other:         'bg-gray-100 text-gray-600',
  };

  function fmtDatetime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('en-PH', {
      year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'
    });
  }

  function openEdit(log) {
    (window).openLogModal({
      id:            log.id,
      province_key:  province.key,
      province_name: province.name,
      title:         log.title,
      description:   log.description,
      activity_type: log.activity_type,
      location:      log.location,
      visited_at:    log.visited_at,
      trip_id:       log.trip_id,
    });
  }

  function buildLogCard(log) {
    const colorClass = TYPE_COLORS[log.activity_type] ?? 'bg-gray-100 text-gray-600';
    const typeLabel  = TYPE_LABELS[log.activity_type] ?? log.activity_type;
    const div = document.createElement('div');
    div.className = 'log-card bg-white rounded-2xl border border-gray-100 shadow-sm px-4 py-3 space-y-2';
    div.dataset.logId = log.id;

    const metaHtml = (log.location || log.visited_at) ? `
      <div class="flex items-center gap-3 text-[11px] text-gray-400 flex-wrap">
        ${log.location ? `<span class="flex items-center gap-1">
          <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          ${log.location}
        </span>` : ''}
        ${log.visited_at ? `<span class="flex items-center gap-1">
          <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          ${fmtDatetime(log.visited_at)}
        </span>` : ''}
      </div>` : '';

    const tripHtml = log._trip_title ? `
      <div class="pt-1 border-t border-gray-50">
        <a href="/trips/${log.trip_id}" class="flex items-center gap-1.5 text-[11px] text-sky-600 hover:text-sky-700 font-medium transition-colors">
          <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          ${log._trip_title}
        </a>
      </div>` : '';

    div.innerHTML = `
      <div class="flex items-start justify-between gap-2">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-800">${log.title}</p>
          <div class="flex items-center gap-2 mt-0.5 flex-wrap">
            <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full ${colorClass}">${typeLabel}</span>
          </div>
        </div>
        <button class="edit-log-btn shrink-0 p-1 text-gray-300 hover:text-gray-500 transition-colors" aria-label="Edit log">
          <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        </button>
      </div>
      ${metaHtml}
      ${log.description ? `<p class="text-xs text-gray-500 leading-relaxed line-clamp-2">${log.description}</p>` : ''}
      ${tripHtml}
    `;
    div.querySelector('.edit-log-btn')?.addEventListener('click', () => openEdit(log));
    return div;
  }

  function updateCount(delta) {
    const badge = document.getElementById('log-count-badge');
    const list  = document.getElementById('log-list');
    if (!list) return;
    const current = badge ? parseInt(badge.textContent?.replace(/\D/g,'') || '0') : 0;
    const next = current + delta;
    if (badge) {
      if (next <= 0) badge.remove();
      else badge.textContent = `(${next})`;
    } else if (next > 0) {
      const h2 = list.previousElementSibling?.querySelector('h2');
      if (h2) {
        const s = document.createElement('span');
        s.id = 'log-count-badge';
        s.className = 'ml-1.5 text-xs font-normal text-gray-400';
        s.textContent = `(${next})`;
        h2.appendChild(s);
      }
    }
  }

  // ── Add log ────────────────────────────────────────────────────────────
  document.getElementById('add-log-btn')?.addEventListener('click', () => {
    (window).openLogModal({ province_key: province.key, province_name: province.name });
  });

  // Wire SSR-rendered edit buttons
  document.querySelectorAll('.edit-log-btn').forEach(btn => {
    btn.addEventListener('click', () => openEdit(JSON.parse(btn.dataset.log ?? '{}')));
  });

  // ── Live updates ───────────────────────────────────────────────────────
  window.addEventListener('province-log-created', (e) => {
    const { log } = e.detail;
    document.getElementById('log-empty')?.remove();
    document.getElementById('log-list')?.prepend(buildLogCard(log));
    updateCount(1);
  });

  window.addEventListener('province-log-updated', (e) => {
    const { log } = e.detail;
    document.querySelector(`[data-log-id="${log.id}"]`)?.replaceWith(buildLogCard(log));
  });

  window.addEventListener('province-log-deleted', (e) => {
    const { log_id } = e.detail;
    document.querySelector(`[data-log-id="${log_id}"]`)?.remove();
    updateCount(-1);
    const list = document.getElementById('log-list');
    if (list && list.children.length === 0) {
      const empty = document.createElement('div');
      empty.id = 'log-empty';
      empty.className = 'text-center py-10 text-sm text-gray-400 bg-white rounded-2xl border border-dashed border-gray-200';
      empty.innerHTML = 'No travel logs yet.<br/><span class="text-xs">Tap "Add Log" to start.</span>';
      list.appendChild(empty);
    }
  });
</script>
