---
import PagePlate from "@/layouts/PagePlate.astro";
import { supabase } from "@/lib/supabase";

const user_id = Astro.locals.user_id;
if (!user_id) return Astro.redirect("/signin");

const { data: profileData } = await supabase.rpc('get_user_profile_data', { p_user_id: user_id });

const userData = profileData?.profile     || {};
const userInfo = profileData?.information || {};
---

<PagePlate title="Basic Info">
<div class="min-h-screen bg-gray-50">

  <!-- Sticky header -->
  <div class="sticky top-0 z-20 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/profile/edit" class="p-1.5 -ml-1.5 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors" aria-label="Back">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <h1 class="text-base font-semibold text-gray-900">Basic Info</h1>
    </div>
  </div>

  <div class="max-w-xl mx-auto px-4 py-6">
    <form id="basic-info-form" class="space-y-5">

      <!-- Display Name -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 space-y-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400">Identity</p>

        <div>
          <label for="full_name" class="block text-sm font-medium text-gray-700 mb-1.5">Display Name</label>
          <input
            type="text"
            id="full_name"
            name="full_name"
            value={userData.full_name || ''}
            maxlength={200}
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
            placeholder="Your display name"
          />
        </div>

        <div>
          <label for="username" class="block text-sm font-medium text-gray-700 mb-1.5">Username</label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm">@</span>
            <input
              type="text"
              id="username"
              name="username"
              value={userData.username || ''}
              minlength={3}
              maxlength={50}
              class="w-full pl-8 pr-10 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="username"
            />
            <div id="username-status" class="absolute right-3 top-1/2 -translate-y-1/2"></div>
          </div>
          <p id="username-message" class="mt-1 text-xs hidden"></p>
        </div>
      </div>

      <!-- Bio -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 space-y-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400">About</p>

        <div>
          <label for="bio" class="block text-sm font-medium text-gray-700 mb-1.5">Bio</label>
          <textarea
            id="bio"
            name="bio"
            maxlength={280}
            rows={4}
            class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all resize-none text-sm"
            placeholder="Share a little about your travel style…"
          >{userData.bio || ''}</textarea>
          <p class="mt-1 text-xs text-gray-400 text-right">
            <span id="bio-count">{(userData.bio || '').length}</span>/280
          </p>
        </div>
      </div>

      <!-- Location -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 space-y-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400">Location</p>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="location_city" class="block text-sm font-medium text-gray-700 mb-1.5">City</label>
            <input
              type="text"
              id="location_city"
              name="location_city"
              value={userInfo.location_city || ''}
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="City"
            />
          </div>
          <div>
            <label for="location_country" class="block text-sm font-medium text-gray-700 mb-1.5">Country</label>
            <input
              type="text"
              id="location_country"
              name="location_country"
              value={userInfo.location_country || ''}
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="Country"
            />
          </div>
        </div>
      </div>

      <!-- Error -->
      <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 rounded-xl">
        <p id="form-error-message" class="text-sm text-red-600"></p>
      </div>

      <!-- Save -->
      <button
        type="submit"
        id="save-btn"
        class="w-full py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold shadow-sm transition-colors disabled:opacity-50 flex items-center justify-center gap-2"
      >
        <span id="save-spinner" class="hidden">
          <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
        </span>
        <span id="save-text">Save Changes</span>
      </button>

    </form>
  </div>
</div>
</PagePlate>

<script>
  import { actions } from 'astro:actions';
  import { showToast } from '@/scripts/Toast';

  let usernameCheckTimeout: ReturnType<typeof setTimeout>;
  const usernameInput  = document.getElementById('username') as HTMLInputElement;
  const usernameStatus = document.getElementById('username-status') as HTMLElement;
  const usernameMsg    = document.getElementById('username-message') as HTMLElement;
  const originalUsername = usernameInput?.value;

  usernameInput?.addEventListener('input', () => {
    clearTimeout(usernameCheckTimeout);
    const val = usernameInput.value.trim();

    if (val.length < 3) { usernameStatus.innerHTML = ''; usernameMsg.classList.add('hidden'); return; }
    if (val === originalUsername) {
      usernameStatus.innerHTML = '<svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>';
      usernameMsg.classList.add('hidden'); return;
    }
    usernameStatus.innerHTML = '<svg class="animate-spin h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';

    usernameCheckTimeout = setTimeout(async () => {
      const { data } = await actions.onboarding.checkUsername({ username: val });
      if (data?.available) {
        usernameStatus.innerHTML = '<svg class="h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>';
        usernameMsg.classList.add('hidden');
      } else {
        usernameStatus.innerHTML = '<svg class="h-4 w-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>';
        usernameMsg.textContent = 'Username already taken';
        usernameMsg.className = 'mt-1 text-xs text-red-500';
      }
    }, 500);
  });

  const bioTextarea = document.getElementById('bio') as HTMLTextAreaElement;
  const bioCount    = document.getElementById('bio-count') as HTMLElement;
  bioTextarea?.addEventListener('input', () => {
    bioCount.textContent = bioTextarea.value.length.toString();
  });

  const form       = document.getElementById('basic-info-form') as HTMLFormElement;
  const saveBtn    = document.getElementById('save-btn') as HTMLButtonElement;
  const saveText   = document.getElementById('save-text') as HTMLElement;
  const saveSpinner = document.getElementById('save-spinner') as HTMLElement;
  const errorDiv   = document.getElementById('form-error') as HTMLElement;
  const errorMsg   = document.getElementById('form-error-message') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (usernameStatus?.innerHTML.includes('text-red-500')) {
      errorMsg.textContent = 'Please choose a different username';
      errorDiv.classList.remove('hidden'); return;
    }

    errorDiv.classList.add('hidden');
    saveBtn.disabled = true;
    saveText.textContent = 'Saving…';
    saveSpinner.classList.remove('hidden');

    const fd = new FormData(form);
    const { error } = await actions.onboarding.updateProfile({
      username: fd.get('username') as string,
      bio: fd.get('bio') as string || undefined,
      location_city: fd.get('location_city') as string || undefined,
      location_country: fd.get('location_country') as string || undefined,
    });

    if (error) {
      errorMsg.textContent = error.message;
      errorDiv.classList.remove('hidden');
      saveBtn.disabled = false;
      saveText.textContent = 'Save Changes';
      saveSpinner.classList.add('hidden');
    } else {
      showToast({ message: 'Profile updated!', type: 'success' });
      setTimeout(() => window.location.href = '/profile/edit', 1000);
    }
  });
</script>
