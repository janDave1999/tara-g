---
import PagePlate from "@/layouts/PagePlate.astro";
import { supabase } from "@/lib/supabase";

const user_id = Astro.locals.user_id;
if (!user_id) return Astro.redirect("/signin");

const { data: profileData } = await supabase.rpc('get_user_profile_data', { p_user_id: user_id });
const prefs = profileData?.preferences || {};

const TRAVEL_STYLES = [
  { value: 'solo',        label: 'Solo Travel', icon: '🎒' },
  { value: 'group',       label: 'Group Travel', icon: '👥' },
  { value: 'family',      label: 'Family',       icon: '👨‍👩‍👧‍👦' },
  { value: 'couples',     label: 'Couples',      icon: '💑' },
  { value: 'backpacking', label: 'Backpacking',  icon: '🏕️' },
  { value: 'luxury',      label: 'Luxury',       icon: '✨' },
];

const ACCOMMODATION_TYPES = [
  { value: 'hotel',      label: 'Hotel',      icon: '🏨' },
  { value: 'hostel',     label: 'Hostel',     icon: '🛏️' },
  { value: 'airbnb',     label: 'Airbnb',     icon: '🏠' },
  { value: 'camping',    label: 'Camping',    icon: '⛺' },
  { value: 'resort',     label: 'Resort',     icon: '🏖️' },
  { value: 'guesthouse', label: 'Guesthouse', icon: '🏡' },
];
---

<PagePlate title="Travel Preferences">
<div class="min-h-screen bg-gray-50">

  <!-- Sticky header -->
  <div class="sticky top-0 z-20 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/profile/edit" class="p-1.5 -ml-1.5 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors" aria-label="Back">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <h1 class="text-base font-semibold text-gray-900">Travel Preferences</h1>
    </div>
  </div>

  <div class="max-w-xl mx-auto px-4 py-6">
    <form id="prefs-form" class="space-y-4">

      <!-- Budget -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-3">Budget Range (per day)</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {['budget', 'moderate', 'luxury', 'any'].map((range) => (
            <label class="cursor-pointer">
              <input type="radio" name="budget_range" value={range} class="hidden peer" checked={prefs.budget_range === range} />
              <div class="py-2.5 border-2 border-gray-100 rounded-xl text-center peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:border-gray-200 transition-all text-xs font-semibold text-gray-700 capitalize">
                {range === 'any' ? 'Any' : range}
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Travel Style -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-3">Travel Style</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {TRAVEL_STYLES.map((style) => (
            <label class="cursor-pointer">
              <input type="checkbox" name="travel_style" value={style.value} class="hidden peer"
                checked={Array.isArray(prefs.travel_style) && prefs.travel_style.includes(style.value)} />
              <div class="p-3 border-2 border-gray-100 rounded-xl flex items-center gap-2.5 peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:border-gray-200 transition-all">
                <span class="text-xl">{style.icon}</span>
                <span class="text-xs font-semibold text-gray-700">{style.label}</span>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Pace -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-3">Travel Pace</p>
        <div class="grid grid-cols-4 gap-2">
          {[
            { value: 'relaxed',  label: 'Relaxed' },
            { value: 'moderate', label: 'Moderate' },
            { value: 'fast',     label: 'Fast' },
            { value: 'any',      label: 'Any' },
          ].map((pace) => (
            <label class="cursor-pointer">
              <input type="radio" name="pace_preference" value={pace.value} class="hidden peer" checked={prefs.pace_preference === pace.value} />
              <div class="py-2.5 border-2 border-gray-100 rounded-xl text-center peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:border-gray-200 transition-all text-xs font-semibold text-gray-700">
                {pace.label}
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Accommodation -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400 mb-3">Preferred Accommodation</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {ACCOMMODATION_TYPES.map((type) => (
            <label class="cursor-pointer">
              <input type="checkbox" name="accommodation_type" value={type.value} class="hidden peer"
                checked={Array.isArray(prefs.accommodation_type) && prefs.accommodation_type.includes(type.value)} />
              <div class="p-3 border-2 border-gray-100 rounded-xl flex items-center gap-2.5 peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:border-gray-200 transition-all">
                <span class="text-xl">{type.icon}</span>
                <span class="text-xs font-semibold text-gray-700">{type.label}</span>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Group Size + Languages -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 space-y-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-400">More Details</p>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="preferred_group_size" class="block text-xs font-medium text-gray-600 mb-1.5">Preferred Group Size</label>
            <input type="number" id="preferred_group_size" name="preferred_group_size" min="1" max="50"
              value={prefs.preferred_group_size || ''}
              class="w-full px-3 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none text-sm" placeholder="e.g. 4" />
          </div>
          <div>
            <label for="max_group_size" class="block text-xs font-medium text-gray-600 mb-1.5">Maximum Group Size</label>
            <input type="number" id="max_group_size" name="max_group_size" min="1" max="50"
              value={prefs.max_group_size || ''}
              class="w-full px-3 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none text-sm" placeholder="e.g. 10" />
          </div>
        </div>

        <div>
          <label for="languages_spoken" class="block text-xs font-medium text-gray-600 mb-1.5">Languages Spoken</label>
          <input type="text" id="languages_spoken" name="languages_spoken"
            value={Array.isArray(prefs.languages_spoken) ? prefs.languages_spoken.join(', ') : ''}
            class="w-full px-3 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none text-sm"
            placeholder="English, Filipino (comma-separated)" />
        </div>

        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="willing_to_split_costs" id="willing_to_split_costs"
            class="w-4 h-4 rounded text-blue-600 border-gray-300"
            checked={prefs.willing_to_split_costs === true} />
          <span class="text-sm text-gray-700">Willing to split costs with travel companions</span>
        </label>
      </div>

      <!-- Error -->
      <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 rounded-xl">
        <p id="form-error-message" class="text-sm text-red-600"></p>
      </div>

      <!-- Save -->
      <button
        type="submit"
        id="save-btn"
        class="w-full py-3.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold shadow-sm transition-colors disabled:opacity-50 flex items-center justify-center gap-2"
      >
        <span id="save-spinner" class="hidden">
          <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
        </span>
        <span id="save-text">Save Preferences</span>
      </button>

    </form>
  </div>
</div>
</PagePlate>

<script>
  import { actions } from 'astro:actions';
  import { showToast } from '@/scripts/Toast';

  const form      = document.getElementById('prefs-form') as HTMLFormElement;
  const saveBtn   = document.getElementById('save-btn') as HTMLButtonElement;
  const saveText  = document.getElementById('save-text') as HTMLElement;
  const saveSpinner = document.getElementById('save-spinner') as HTMLElement;
  const errorDiv  = document.getElementById('form-error') as HTMLElement;
  const errorMsg  = document.getElementById('form-error-message') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    saveBtn.disabled = true;
    saveText.textContent = 'Saving…';
    saveSpinner.classList.remove('hidden');

    const fd = new FormData(form);
    const parseArr = (val: string | null) =>
      val ? val.split(',').map(s => s.trim()).filter(Boolean) : undefined;

    const preferences: Record<string, any> = {};

    const budget = fd.get('budget_range');
    if (budget) preferences.budget_range = budget;

    const styles = fd.getAll('travel_style');
    if (styles.length) preferences.travel_style = styles;

    const pace = fd.get('pace_preference');
    if (pace) preferences.pace_preference = pace;

    const accommodations = fd.getAll('accommodation_type');
    if (accommodations.length) preferences.accommodation_type = accommodations;

    const prefSize = fd.get('preferred_group_size');
    if (prefSize) preferences.preferred_group_size = parseInt(prefSize as string);

    const maxSize = fd.get('max_group_size');
    if (maxSize) preferences.max_group_size = parseInt(maxSize as string);

    preferences.willing_to_split_costs = fd.get('willing_to_split_costs') === 'on';

    const langs = parseArr(fd.get('languages_spoken') as string);
    if (langs) preferences.languages_spoken = langs;

    const { error } = await actions.onboarding.setTravelPreferences(preferences);

    if (error) {
      errorMsg.textContent = error.message;
      errorDiv.classList.remove('hidden');
      saveBtn.disabled = false;
      saveText.textContent = 'Save Preferences';
      saveSpinner.classList.add('hidden');
    } else {
      showToast({ message: 'Preferences saved!', type: 'success' });
      setTimeout(() => window.location.href = '/profile/edit', 1000);
    }
  });
</script>
