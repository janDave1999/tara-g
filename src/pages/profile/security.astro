---
import PagePlate from "@/layouts/PagePlate.astro";
import { supabaseAdmin } from "@/lib/supabase";

const user_id = Astro.locals.user_id;
if (!user_id) return Astro.redirect("/signin");

const email = Astro.locals.email ?? "";

// Fetch auth identities to know which providers are connected
const { data: { user } } = await supabaseAdmin.auth.admin.getUserById(user_id);
const identities = user?.identities ?? [];
const userMetadata = user?.user_metadata ?? {};
const hasPasswordFromIdentity = identities.some(i => i.provider === "email");
const hasPassword = hasPasswordFromIdentity || userMetadata.password_set === true;
const hasGoogle    = identities.some(i => i.provider === "google");
const hasFacebook  = identities.some(i => i.provider === "facebook");
---

<PagePlate title="Account & Security">
<div class="min-h-screen bg-gray-50">

  <!-- Sticky header -->
  <div class="sticky top-0 z-20 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-xl mx-auto px-4 h-14 flex items-center gap-3">
      <a href="/profile/edit" class="p-1.5 -ml-1.5 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors" aria-label="Back">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>
      <h1 class="text-base font-semibold text-gray-900">Account & Security</h1>
    </div>
  </div>

  <div class="max-w-xl mx-auto px-4 py-6 space-y-4">

    <!-- ── Email ─────────────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <p class="section-label">Email Address</p>
      </div>

      <div class="px-5 pb-5">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-semibold text-gray-900">{email}</p>
            <p class="text-xs text-gray-400 mt-0.5">Your sign-in email</p>
          </div>
          <button id="emailToggle" class="text-xs font-semibold text-blue-600 hover:text-blue-700 transition-colors">
            Change
          </button>
        </div>

        <form id="emailForm" class="hidden space-y-3">
          <div>
            <label for="new_email" class="block text-xs font-medium text-gray-600 mb-1">New email address</label>
            <input
              type="email" id="new_email" name="new_email" autocomplete="email"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="new@example.com"
            />
          </div>
          <div id="emailError" class="hidden text-xs text-red-600 px-1"></div>
          <div id="emailSuccess" class="hidden text-xs text-green-600 px-1"></div>
          <div class="flex gap-2">
            <button type="button" id="emailCancel" class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">Cancel</button>
            <button type="submit" id="emailSave" class="flex-1 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors disabled:opacity-50">Save</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Password ───────────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <p class="section-label">Password</p>
      </div>

      <div class="px-5 pb-5">
        <div class="flex items-center justify-between mb-4">
          <div>
            <p class="text-sm font-semibold text-gray-900">{hasPassword ? "••••••••" : "No password set"}</p>
            <p class="text-xs text-gray-400 mt-0.5">
              {hasPassword ? "Last changed: unknown" : "Set a password to enable email sign-in"}
            </p>
          </div>
          <button id="passwordToggle" class="text-xs font-semibold text-blue-600 hover:text-blue-700 transition-colors">
            {hasPassword ? "Change" : "Set"}
          </button>
        </div>

        <form id="passwordForm" class="hidden space-y-3">
          {!hasPasswordFromIdentity && (
            <div class="p-3 bg-blue-50 border border-blue-200 rounded-lg">
              <p class="text-xs text-blue-700">You'll be able to sign in with email & password. You may need to sign in again.</p>
            </div>
          )}
          {hasPassword && (
            <div>
              <label for="current_password" class="block text-xs font-medium text-gray-600 mb-1">Current password</label>
              <input
                type="password" id="current_password" name="current_password" autocomplete="current-password"
                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
                placeholder="Enter current password"
              />
            </div>
          )}
          <div>
            <label for="new_password" class="block text-xs font-medium text-gray-600 mb-1">New password</label>
            <input
              type="password" id="new_password" name="new_password" autocomplete="new-password"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="Min. 8 characters"
            />
          </div>
          <div>
            <label for="confirm_password" class="block text-xs font-medium text-gray-600 mb-1">Confirm new password</label>
            <input
              type="password" id="confirm_password" name="confirm_password" autocomplete="new-password"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-sm"
              placeholder="Repeat new password"
            />
          </div>
          <div id="passwordError" class="hidden text-xs text-red-600 px-1"></div>
          <div class="flex gap-2">
            <button type="button" id="passwordCancel" class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">Cancel</button>
            <button type="submit" id="passwordSave" class="flex-1 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition-colors disabled:opacity-50">Save</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Sign-in Methods ────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <p class="section-label">Sign-in Methods</p>
      </div>

      <div class="divide-y divide-gray-50">
        <!-- Email/Password -->
        <div class="flex items-center gap-4 px-5 py-3.5">
          <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-900">Email & Password</p>
            <p class="text-xs text-gray-400 mt-0.5">{email}</p>
          </div>
          {hasPassword
            ? <span class="text-[11px] font-bold text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">Connected</span>
            : <span class="text-[11px] font-bold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">Not set</span>
          }
        </div>

        <!-- Google -->
        <div class="flex items-center gap-4 px-5 py-3.5">
          <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-900">Google</p>
            <p class="text-xs text-gray-400 mt-0.5">Sign in with your Google account</p>
          </div>
          {hasGoogle
            ? <span class="text-[11px] font-bold text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">Connected</span>
            : <span class="text-[11px] font-bold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">Not connected</span>
          }
        </div>

        <!-- Facebook -->
        <div class="flex items-center gap-4 px-5 py-3.5">
          <div class="w-9 h-9 rounded-xl bg-[#1877F2]/10 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-gray-900">Facebook</p>
            <p class="text-xs text-gray-400 mt-0.5">Sign in with your Facebook account</p>
          </div>
          {hasFacebook
            ? <span class="text-[11px] font-bold text-green-600 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">Connected</span>
            : <span class="text-[11px] font-bold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">Not connected</span>
          }
        </div>
      </div>
    </div>

    <!-- ── Sessions ───────────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <p class="section-label">Sessions</p>
      </div>
      <div class="px-5 pb-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-semibold text-gray-900">Sign out of all devices</p>
            <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">Ends all active sessions including this one. You'll need to sign in again.</p>
          </div>
          <button id="signOutAllBtn"
            class="shrink-0 text-xs font-semibold text-orange-600 hover:text-orange-700 border border-orange-200 hover:border-orange-300 bg-orange-50 hover:bg-orange-100 px-3 py-1.5 rounded-xl transition-colors">
            Sign out all
          </button>
        </div>
      </div>
    </div>

    <!-- ── Danger Zone ────────────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-red-100 shadow-sm overflow-hidden">
      <div class="px-5 pt-5 pb-3">
        <p class="section-label text-red-400">Danger Zone</p>
      </div>
      <div class="px-5 pb-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-semibold text-gray-900">Delete account</p>
            <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">Permanently deletes your account and all associated data. This cannot be undone.</p>
          </div>
          <button id="deleteAccountBtn"
            class="shrink-0 text-xs font-semibold text-red-600 hover:text-red-700 border border-red-200 hover:border-red-300 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-xl transition-colors">
            Delete
          </button>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Delete confirmation dialog -->
<dialog id="deleteDialog"
  class="rounded-2xl border border-gray-200 shadow-2xl p-6 max-w-sm w-full mx-auto backdrop:bg-black/40">
  <h2 class="text-base font-bold text-gray-900 mb-2">Delete account?</h2>
  <p class="text-sm text-gray-500 mb-5 leading-relaxed">
    This will permanently delete your account, trips, and all associated data. <strong class="text-gray-700">This cannot be undone.</strong>
  </p>
  <div class="flex gap-3">
    <button id="deleteCancelBtn" class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
      Cancel
    </button>
    <button id="deleteConfirmBtn" class="flex-1 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-semibold transition-colors disabled:opacity-50">
      Delete my account
    </button>
  </div>
</dialog>
</PagePlate>

<style>
  .section-label { font-size: 10px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.1em; }
</style>

<script>
  import { actions } from 'astro:actions';
  import { showToast } from '@/scripts/Toast';

  // ── Helpers ────────────────────────────────────────────────────
  const toggle = (el: HTMLElement | null, show: boolean) => el?.classList.toggle('hidden', !show);
  const setBusy = (btn: HTMLButtonElement | null, busy: boolean, label: string) => {
    if (!btn) return;
    btn.disabled = busy;
    btn.textContent = busy ? 'Saving…' : label;
  };

  // ── Email ──────────────────────────────────────────────────────
  const emailForm    = document.getElementById('emailForm')    as HTMLFormElement;
  const emailToggle  = document.getElementById('emailToggle')  as HTMLButtonElement;
  const emailCancel  = document.getElementById('emailCancel')  as HTMLButtonElement;
  const emailSave    = document.getElementById('emailSave')    as HTMLButtonElement;
  const emailError   = document.getElementById('emailError')   as HTMLElement;
  const emailSuccess = document.getElementById('emailSuccess') as HTMLElement;

  emailToggle?.addEventListener('click', () => toggle(emailForm, true));
  emailCancel?.addEventListener('click', () => {
    toggle(emailForm, false);
    toggle(emailError, false);
    toggle(emailSuccess, false);
  });

  emailForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    toggle(emailError, false);
    toggle(emailSuccess, false);
    setBusy(emailSave, true, 'Save');

    const fd = new FormData(emailForm);
    const { error } = await actions.auth.changeEmail({
      email: fd.get('new_email') as string,
    });

    setBusy(emailSave, false, 'Save');
    if (error) {
      emailError.textContent = error.message;
      toggle(emailError, true);
    } else {
      emailSuccess.textContent = 'Check your new email for a confirmation link.';
      toggle(emailSuccess, true);
      emailForm.reset();
    }
  });

  // ── Password ───────────────────────────────────────────────────
  const passwordForm   = document.getElementById('passwordForm')   as HTMLFormElement;
  const passwordToggle = document.getElementById('passwordToggle') as HTMLButtonElement;
  const passwordCancel = document.getElementById('passwordCancel') as HTMLButtonElement;
  const passwordSave   = document.getElementById('passwordSave')   as HTMLButtonElement;
  const passwordError  = document.getElementById('passwordError')  as HTMLElement;

  passwordToggle?.addEventListener('click', () => toggle(passwordForm, true));
  passwordCancel?.addEventListener('click', () => {
    toggle(passwordForm, false);
    toggle(passwordError, false);
  });

  passwordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    toggle(passwordError, false);

    const fd = new FormData(passwordForm);
    const newPassword     = fd.get('new_password') as string;
    const confirmPassword = fd.get('confirm_password') as string;

    if (newPassword !== confirmPassword) {
      passwordError.textContent = "Passwords don't match";
      toggle(passwordError, true);
      return;
    }

    setBusy(passwordSave, true, 'Save');
    const { error } = await actions.auth.changePassword({
      currentPassword: fd.get('current_password') as string || undefined,
      newPassword,
    });

    setBusy(passwordSave, false, 'Save');
    if (error) {
      passwordError.textContent = error.message;
      toggle(passwordError, true);
    } else {
      showToast({ message: 'Password updated!', type: 'success' });
      toggle(passwordForm, false);
      passwordForm.reset();
    }
  });

  // ── Sign out all ───────────────────────────────────────────────
  document.getElementById('signOutAllBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('signOutAllBtn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Signing out…';

    const { error } = await actions.auth.signOutAll();
    if (error) {
      showToast({ message: 'Something went wrong. Try again.', type: 'error' });
      btn.disabled = false;
      btn.textContent = 'Sign out all';
    } else {
      window.location.href = '/signin';
    }
  });

  // ── Delete account ─────────────────────────────────────────────
  const deleteDialog  = document.getElementById('deleteDialog')  as HTMLDialogElement;
  const deleteConfirm = document.getElementById('deleteConfirmBtn') as HTMLButtonElement;
  const deleteCancel  = document.getElementById('deleteCancelBtn')  as HTMLButtonElement;

  document.getElementById('deleteAccountBtn')?.addEventListener('click', () => deleteDialog?.showModal());
  deleteCancel?.addEventListener('click', () => deleteDialog?.close());

  deleteConfirm?.addEventListener('click', async () => {
    deleteConfirm.disabled = true;
    deleteConfirm.textContent = 'Deleting…';

    const { error } = await actions.auth.deleteAccount();
    if (error) {
      showToast({ message: 'Could not delete account. Try again.', type: 'error' });
      deleteConfirm.disabled = false;
      deleteConfirm.textContent = 'Delete my account';
      deleteDialog?.close();
    } else {
      window.location.href = '/';
    }
  });
</script>
